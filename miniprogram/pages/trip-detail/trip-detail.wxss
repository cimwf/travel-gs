/* pages/trip-detail/trip-detail.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

page {
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 180rpx;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 顶部图片区域 ========== */
.header {
  position: relative;
  height: 480rpx;
  width: 100%;
  overflow: hidden;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.header-image {
  width: 100%;
  height: 100%;
  display: block;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.3) 0%,
    rgba(0,0,0,0) 30%,
    rgba(0,0,0,0) 50%,
    rgba(0,0,0,0.75) 100%
  );
}

/* ========== 导航按钮 ========== */
.nav-btns {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 24rpx;
  z-index: 20;
}

.nav-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 40rpx;
  color: white;
  font-weight: 300;
}

.nav-dots {
  font-size: 28rpx;
  color: white;
  letter-spacing: 4rpx;
}

/* ========== 底部标题信息 ========== */
.header-content {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
}

.status-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.status-tag {
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-open {
  background: var(--success-color);
  color: white;
}

.status-full {
  background: var(--warning-color);
  color: white;
}

.status-ended,
.status-cancelled {
  background: rgba(255,255,255,0.25);
  color: white;
}

.remain-tag {
  background: rgba(255,255,255,0.25);
  color: white;
}

.trip-title {
  font-size: 52rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 12rpx;
}

.trip-location {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* ========== 内容区域 ========== */
.content {
  padding: 24rpx;
}

/* ========== 列表式信息卡片 ========== */
.info-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.info-item {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid var(--bg-color);
}

.info-item.last-item {
  padding-bottom: 0;
  border-bottom: none;
}

.info-emoji {
  font-size: 56rpx;
  line-height: 1;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 10rpx;
}

.info-value {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ========== 卡片通用样式 ========== */
.creator-card,
.note-card,
.members-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.card-icon {
  font-size: 40rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ========== 发起人信息 ========== */
.creator-info {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.creator-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f5f5f5;
}

.creator-avatar-text {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 44rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.creator-text {
  flex: 1;
}

.creator-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.creator-meta {
  font-size: 24rpx;
  color: var(--text-hint);
}

.follow-btn {
  padding: 18rpx 40rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  border-radius: 44rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* ========== 行程说明 ========== */
.note-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ========== 已加入成员 ========== */
.members-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}

.members-count {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.members-grid {
  display: flex;
  gap: 32rpx;
  flex-wrap: wrap;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  background: #f5f5f5;
}

.member-avatar-text {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 600;
}

.member-name {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: center;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.placeholder-avatar {
  background: var(--bg-color);
  border: 4rpx dashed var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-hint);
  font-size: 44rpx;
}

.placeholder-name {
  color: var(--text-hint);
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 40rpx;
}

/* ========== 底部申请按钮 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.apply-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 108rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.4);
}

.apply-btn.disabled {
  background: #CCCCCC;
  box-shadow: none;
}
