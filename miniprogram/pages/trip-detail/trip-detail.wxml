<!--pages/trip-detail/trip-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 顶部图片区域 -->
    <view class="header">
      <image class="header-image" src="{{trip.placeImage || 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&h=300&fit=crop'}}" mode="aspectFill"></image>
      <view class="header-overlay"></view>

      <!-- 导航按钮 -->
      <view class="nav-btns" style="padding-top: {{statusBarHeight}}px;">
        <view class="nav-btn" bindtap="onBackTap">
          <text class="nav-arrow">‹</text>
        </view>
      </view>

      <!-- 底部标题信息 -->
      <view class="header-content">
        <view class="status-tags">
          <view class="status-tag status-joined" wx:if="{{hasJoined && !isCreator}}">✓ 已加入</view>
          <view class="status-tag status-{{trip.status}}" wx:else>{{statusText}}</view>
          <view class="status-tag remain-tag" wx:if="{{remainCount > 0 && !hasJoined}}">还剩{{remainCount}}个名额</view>
        </view>
        <view class="trip-title">{{trip.title || trip.placeName}}</view>
        <view class="trip-location">🏔️ {{trip.placeName}} · {{trip.placeHighlight || '北京周边'}}</view>
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="content">
      <!-- 行程信息卡片 -->
      <view class="info-card">
        <view class="card-header">
          <view class="card-icon-svg">
            <view class="icon-calendar"></view>
          </view>
          <text class="card-title">行程信息</text>
        </view>
        <view class="info-list">
          <view class="info-row">
            <text class="info-label">📅 出发日期</text>
            <text class="info-value">{{trip.dateText || trip.date}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">📍 出发地</text>
            <text class="info-value">{{trip.departure || '待定'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">👥 招募人数</text>
            <text class="info-value">{{trip.currentCount}}-{{trip.totalCount || (trip.currentCount + trip.needCount)}}人</text>
          </view>
        </view>
      </view>

      <!-- 发起人信息 -->
      <view class="creator-card">
        <view class="card-header">
          <text class="card-icon">👤</text>
          <text class="card-title">发起人</text>
        </view>
        <view class="creator-info">
          <image class="creator-avatar" src="{{trip.creatorAvatar}}" wx:if="{{trip.creatorAvatar}}" mode="aspectFill"></image>
          <view class="creator-avatar-text" style="background: linear-gradient(135deg, #4A90E2, #6BA3E8);" wx:else>
            <text>{{trip.creatorName ? trip.creatorName[0] : '旅'}}</text>
          </view>
          <view class="creator-text">
            <view class="creator-name">{{trip.creatorName || '旅行者'}}</view>
            <view class="creator-meta">行程发起人</view>
          </view>
        </view>
        <!-- 联系方式 - 已加入可见 -->
        <view class="contact-info" wx:if="{{hasJoined && trip.phone}}">
          <view class="contact-tip">🎉 您已加入，可联系发起人</view>
          <view class="contact-row">
            <text class="contact-icon">💬</text>
            <text class="contact-value">微信号：{{maskedPhone}}</text>
            <view class="copy-btn" bindtap="onCopyPhone">复制</view>
          </view>
        </view>
      </view>

      <!-- 行程说明 -->
      <view class="note-card" wx:if="{{trip.remark}}">
        <view class="card-header">
          <text class="card-icon">📝</text>
          <text class="card-title">行程说明</text>
        </view>
        <view class="note-text">{{trip.remark}}</view>
      </view>

      <!-- 已加入成员 -->
      <view class="members-card">
        <view class="members-header">
          <text class="card-title">已加入成员</text>
          <text class="members-count">{{trip.currentCount}}/{{trip.totalCount || (trip.currentCount + trip.needCount)}}人</text>
        </view>
        <view class="members-grid">
          <view class="member-item" wx:for="{{participants}}" wx:key="userId" bindtap="onMemberTap" data-member="{{item}}">
            <image class="member-avatar" src="{{item.avatar}}" wx:if="{{item.avatar}}" mode="aspectFill"></image>
            <view class="member-avatar-text" style="background: linear-gradient(135deg, #56AB2F, #A8E6CF);" wx:else>
              <text>{{item.nickname ? item.nickname[0] : '旅'}}</text>
            </view>
            <view class="member-name">{{item.nickname || '旅行者'}}</view>
          </view>
          <!-- 待加入占位 -->
          <view class="member-item placeholder" wx:for="{{remainCount}}" wx:key="index">
            <view class="member-avatar placeholder-avatar">+</view>
            <view class="member-name placeholder-name">待加入</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>
  </block>
</view>

<!-- 底部按钮区域 -->
<view class="footer-bar" wx:if="{{!loading}}">
  <!-- 发起人视角：编辑行程 + 分享招募 -->
  <block wx:if="{{isCreator}}">
    <view class="footer-btn-secondary" bindtap="onEditTrip">编辑行程</view>
    <view class="footer-btn-primary" bindtap="onShareRecruit">分享招募</view>
  </block>

  <!-- 已加入成员视角：退出行程 + 分享给朋友 -->
  <block wx:elif="{{hasJoined}}">
    <view class="footer-btn-danger" bindtap="onQuitTrip">退出行程</view>
    <view class="footer-btn-primary" bindtap="onShareFriends">分享给朋友</view>
  </block>

  <!-- 未加入视角：申请加入 -->
  <block wx:else>
    <view class="footer-btn-full {{canJoin ? '' : 'disabled'}}" bindtap="onJoinTap">
      <text>{{joinBtnText}}</text>
    </view>
  </block>
</view>

<!-- 申请加入弹窗组件 -->
<apply-modal
  show="{{showApplyModal}}"
  placeName="{{trip.placeName}}"
  remainCount="{{remainCount}}"
  tripId="{{trip._id}}"
  toUserId="{{trip.creatorId}}"
  toUserName="{{trip.creatorName}}"
  defaultPhone="{{userInfo.phone || ''}}"
  bind:close="onCloseApplyModal"
  bind:submit="onSubmitApplySuccess"
/>

<!-- 成员管理弹窗 -->
<view class="member-modal-mask" wx:if="{{showMemberModal}}" bindtap="onCloseMemberModal">
  <view class="member-modal" catchtap>
    <!-- 关闭按钮 -->
    <view class="modal-close-btn" bindtap="onCloseMemberModal">
      <text class="modal-close-icon">×</text>
    </view>

    <!-- 成员信息 -->
    <view class="modal-member-info">
      <image class="modal-avatar" src="{{selectedMember.avatar}}" wx:if="{{selectedMember.avatar}}" mode="aspectFill"></image>
      <view class="modal-avatar-text" style="background: linear-gradient(135deg, #56AB2F, #A8E6CF);" wx:else>
        <text>{{selectedMember.nickname ? selectedMember.nickname[0] : '旅'}}</text>
      </view>
      <view class="modal-name">{{selectedMember.nickname || '旅行者'}}</view>
      <view class="modal-join-time">已加入 · {{selectedMember.joinTimeText || '刚刚'}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="modal-actions">
      <view class="modal-btn modal-btn-primary" bindtap="onViewProfile">查看资料</view>
      <view class="modal-btn modal-btn-danger" wx:if="{{isCreator && selectedMember.userId !== trip.creatorId}}" bindtap="onRemoveMember">移除成员</view>
    </view>
  </view>
</view>

<!-- 移除成员确认弹窗 -->
<view class="member-modal-mask" wx:if="{{showRemoveConfirm}}" bindtap="onCloseRemoveConfirm">
  <view class="confirm-modal" catchtap>
    <view class="confirm-icon-wrap">
      <text class="confirm-icon">✕</text>
    </view>
    <view class="confirm-title">确认移除成员？</view>
    <view class="confirm-desc">移除后，该成员将退出此行程，无法查看行程信息。此操作不可撤销。</view>
    <view class="confirm-actions">
      <view class="confirm-btn confirm-btn-cancel" bindtap="onCloseRemoveConfirm">取消</view>
      <view class="confirm-btn confirm-btn-danger" bindtap="onConfirmRemove">确认移除</view>
    </view>
  </view>
</view>
