<!--pages/register/register.wxml-->
<view class="register-page">
  <view class="register-content">
    <!-- 标题 -->
    <view class="register-title">创建账号</view>

    <!-- 注册表单卡片 -->
    <view class="register-form-card">
      <!-- 手机号 -->
      <view class="form-item">
        <view class="form-label">手机号</view>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input
            class="form-input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{phone}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <!-- 设置密码 -->
      <view class="form-item">
        <view class="form-label">设置密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input
            class="form-input"
            type="{{showPassword ? 'text' : 'password'}}"
            placeholder="8-20位，含字母和数字"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
          <view class="eye-icon" bindtap="onTogglePassword">
            <text>{{showPassword ? '👁️' : '🙈'}}</text>
          </view>
        </view>
        <!-- 密码强度 -->
        <view class="password-strength">
          <view class="strength-bar {{strengthLevel >= 1 ? 'active-' + strengthColors[0] : ''}}"></view>
          <view class="strength-bar {{strengthLevel >= 2 ? 'active-' + strengthColors[1] : ''}}"></view>
          <view class="strength-bar {{strengthLevel >= 3 ? 'active-' + strengthColors[2] : ''}}"></view>
        </view>
        <view class="strength-text">密码强度：{{strengthText}}</view>
      </view>

      <!-- 确认密码 -->
      <view class="form-item">
        <view class="form-label">确认密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input
            class="form-input"
            type="{{showConfirmPassword ? 'text' : 'password'}}"
            placeholder="请再次输入密码"
            value="{{confirmPassword}}"
            bindinput="onConfirmPasswordInput"
          />
          <view class="eye-icon" bindtap="onToggleConfirmPassword">
            <text>{{showConfirmPassword ? '👁️' : '🙈'}}</text>
          </view>
        </view>
      </view>

      <!-- 协议勾选 -->
      <view class="agreement-check">
        <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="onToggleAgree">
          <text wx:if="{{agreed}}">✓</text>
        </view>
        <text class="agreement-text">
          我已阅读并同意
          <text class="link" bindtap="onOpenAgreement" data-type="user">《用户协议》</text>
          和
          <text class="link" bindtap="onOpenAgreement" data-type="privacy">《隐私政策》</text>
        </text>
      </view>

      <!-- 注册按钮 -->
      <button
        class="register-btn {{canRegister ? '' : 'disabled'}}"
        bindtap="onRegister"
        loading="{{loading}}"
      >
        注册
      </button>
    </view>

    <!-- 登录引导 -->
    <view class="login-guide">
      <text class="guide-text">已有账号？</text>
      <text class="guide-link" bindtap="onGoLogin">立即登录</text>
    </view>
  </view>
</view>
