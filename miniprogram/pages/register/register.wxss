/* pages/register/register.wxss */
page {
  height: 100%;
  width: 100%;
  overflow-x: hidden;
}

.register-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #4A90E2 0%, #667eea 50%, #764ba2 100%);
  padding: 0 40rpx;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
  position: relative;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 40rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  z-index: 100;
}

.back-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 300;
}

/* 内容区域 */
.register-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  color: white;
  text-align: center;
}

/* 标题 */
.register-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 30px;
}

/* 注册表单卡片 */
.register-form-card {
  background: white;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}

/* 表单项 */
.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 13px;
  color: #4A4A68;
  margin-bottom: 8px;
  font-weight: 500;
  text-align: left;
}

/* 输入框容器 */
.input-wrap {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 12px;
  padding: 0 16px;
}

.input-icon {
  font-size: 18px;
  margin-right: 10px;
}

.form-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 16px;
  color: #1A1A2E;
  padding: 14px 0;
  text-align: left;
}

.input-eye {
  font-size: 14px;
  color: #8E8EA0;
  padding: 10px;
}

/* 眼睛图标 */
.eye-icon {
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

/* 密码强度 */
.password-strength {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.strength-bar {
  flex: 1;
  height: 4px;
  background: #E8E8F0;
  border-radius: 2px;
}

.strength-bar.active-weak {
  background: #FF4D4F;
}

.strength-bar.active-medium {
  background: #FAAD14;
}

.strength-bar.active-strong {
  background: #52C41A;
}

.strength-text {
  font-size: 11px;
  color: #8E8EA0;
  text-align: left;
  margin-top: 4px;
}

/* 协议勾选 */
.agreement-check {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 10px;
  margin-bottom: 20px;
  text-align: left;
}

.checkbox {
  width: 18px;
  height: 18px;
  border: 1px solid #E8E8F0;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
  flex-shrink: 0;
}

.agreement-text-view {
  flex: 1;
}

.checkbox.checked {
  background: #4A90E2;
  border-color: #4A90E2;
  color: white;
  font-size: 12px;
}

.agreement-text {
  font-size: 12px;
  color: #4A4A68;
  line-height: 1.5;
}

.agreement-text .link {
  color: #4A90E2;
}

/* 注册按钮 */
.register-btn {
  padding: 6px;
  background: #4A90E2;
  border: none;
  border-radius: 50px;
  font-size: 17px;
  font-weight: 600;
}

.register-btn button {
  background: #4A90E2;
  color: white;
}

.register-btn.disabled {
  opacity: 0.5;
}

/* 登录引导 */
.login-guide {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.guide-text {
  font-size: 14px;
  opacity: 0.8;
}

.guide-link {
  font-size: 14px;
  font-weight: 600;
  text-decoration: underline;
}
