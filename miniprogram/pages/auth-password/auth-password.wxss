/* pages/auth-password/auth-password.wxss */
page {
  height: 100%;
  width: 100%;
  overflow-x: hidden;
}

.auth-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #4A90E2 0%, #667eea 50%, #764ba2 100%);
  padding: 0 40rpx;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 40rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  z-index: 100;
}

.back-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 300;
}

.auth-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  color: white;
  text-align: center;
}

.auth-logo {
  width: 80px;
  height: 80px;
  background: white;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  margin-bottom: 20px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.15);
}

.auth-title {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 8px;
}

.auth-subtitle {
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 30px;
}

.auth-form-card {
  background: white;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 13px;
  color: #4A4A68;
  margin-bottom: 8px;
  font-weight: 500;
  text-align: left;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 12px;
  padding: 0 16px;
}

.input-icon {
  font-size: 18px;
  margin-right: 10px;
}

.form-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 16px;
  color: #1A1A2E;
  padding: 14px 0;
  text-align: left;
}

.eye-icon {
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.forget-password {
  text-align: right;
  margin-bottom: 20px;
}

.forget-password text {
  font-size: 13px;
  color: #4A90E2;
}

.login-btn {
  padding: 6px;
  background: #4A90E2;
  border: none;
  border-radius: 50px;
  font-size: 17px;
  font-weight: 600;
}

.login-btn button {
  background: #4A90E2;
  color: white;
}

.login-btn.disabled {
  opacity: 0.5;
}

.auth-agreement {
  font-size: 11px;
  opacity: 0.7;
  line-height: 1.6;
}

.auth-agreement .link {
  text-decoration: underline;
}
