/* pages/feedback/feedback.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --bg-color: #F5F7FA;
  --border-color: #E8E8F0;
  --danger-color: #FF4D4F;
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-color);
  padding-left: 20rpx;
  padding-right: 20rpx;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 表单内容 ========== */
.form-content {
  padding: 32rpx;
  width: 100%;
}

.form-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.form-group:last-of-type {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: var(--danger-color);
}

.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0rpx 32rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  font-size: 30rpx;
  background: var(--bg-color);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 24rpx;
  font-size: 30rpx;
  background: var(--bg-color);
  height: 240rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: right;
  margin-top: 8rpx;
}

.submit-btn {
  margin-top: 48rpx;
  padding: 32rpx;
  background: var(--primary-color);
  color: white;
  text-align: center;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.submit-btn:active {
  opacity: 0.9;
}

.input-placeholder {
  color: var(--text-hint);
  height: 100rpx;
  display: flex;
  align-items: center;
}
