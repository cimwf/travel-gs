/* pages/feedback/feedback.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --bg-color: #F5F7FA;
  --border-color: #E8E8F0;
  --danger-color: #FF4D4F;
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-color);
  overflow-x: hidden;
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

/* ========== 表单内容 ========== */
.form-content {
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-group {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.required {
  color: var(--danger-color);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 20rpx;
  font-size: 30rpx;
  background: var(--bg-color);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 20rpx;
  font-size: 30rpx;
  background: var(--bg-color);
  height: 240rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: right;
  margin-top: 12rpx;
}

.input-placeholder {
  color: var(--text-hint);
}

/* ========== 底部提交按钮 ========== */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 2rpx solid var(--border-color);
}

.submit-btn {
  padding: 28rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  text-align: center;
  border-radius: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
}
