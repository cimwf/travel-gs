<!--pages/feedback/feedback.wxml-->
<view class="container">
  <!-- 导航栏 -->
  <view class="nav-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-top">
      <view class="nav-back" bindtap="onBackTap">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">提交建议</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 占位区域 -->
  <view class="nav-placeholder-area" style="height: {{statusBarHeight + 44}}px;"></view>

  <!-- 表单内容 -->
  <view class="form-content">
    <view class="form-card">
      <!-- 标题 -->
      <view class="form-group">
        <view class="form-label">标题（选填）</view>
        <input class="form-input" placeholder="简要描述您的建议" placeholder-class="input-placeholder" value="{{title}}" bindinput="onTitleInput" maxlength="50" />
      </view>

      <!-- 详细描述 -->
      <view class="form-group">
        <view class="form-label">详细描述 <text class="required">*</text></view>
        <textarea class="form-textarea" placeholder="请详细描述您的建议或遇到的问题..." value="{{content}}" bindinput="onContentInput" maxlength="500" />
        <view class="char-count">{{content.length}}/500</view>
      </view>

      <!-- 联系方式 -->
      <view class="form-group">
        <view class="form-label">联系方式（选填）</view>
        <input class="form-input" placeholder="手机号或微信号" placeholder-class="input-placeholder" value="{{contact}}" bindinput="onContactInput" maxlength="30" />
      </view>

      <!-- 提交按钮 -->
      <view class="submit-btn" bindtap="onSubmit">提交</view>
    </view>
  </view>
</view>
