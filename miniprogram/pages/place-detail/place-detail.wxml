<!--pages/place-detail/place-detail.wxml-->
<view class="container">
  <!-- 顶部轮播图区域 -->
  <view class="header">
    <swiper
      class="banner-swiper"
      indicator-dots
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#ffffff"
      autoplay
      circular
      interval="4000"
    >
      <swiper-item wx:for="{{place.images}}" wx:key="*this">
        <image class="banner-image" src="{{item}}" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <!-- 渐变遮罩 -->
    <view class="banner-overlay"></view>

    <!-- 自定义导航栏 -->
    <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
      <!-- 返回按钮 -->
      <view class="nav-btn" bindtap="onBackTap">
        <text class="nav-icon">‹</text>
      </view>
    </view>
  </view>

  <!-- 基本信息区域 -->
  <view class="info-section">
    <!-- 地点名称 -->
    <view class="place-header">
      <view class="place-name">{{place.name}}</view>
      <view class="place-category">
        <text class="category-icon">🏔️</text>
        <text>{{place.category || '山岳风光'}}</text>
      </view>
    </view>

    <!-- 数据指标 -->
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-value">{{place.distance}}km</view>
        <view class="stat-label">距北京市区</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{place.difficulty}}</view>
        <view class="stat-label">难度等级</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{place.rating || '4.8'}}</view>
        <view class="stat-label">用户评分</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{place.duration}}</view>
        <view class="stat-label">建议时长</view>
      </view>
    </view>

    <!-- 标签 -->
    <view class="tags-container">
      <view class="tag" wx:for="{{place.tags}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 元信息 -->
    <view class="meta-info">
      <view class="meta-item">
        <text class="meta-icon">📍</text>
        <view class="meta-content">
          <view class="meta-label">详细地址</view>
          <view class="meta-value">{{place.location}}</view>
        </view>
      </view>
      <view class="meta-item">
        <text class="meta-icon">🕐</text>
        <view class="meta-content">
          <view class="meta-label">开放时间</view>
          <view class="meta-value">{{place.openTime || '全天开放'}}</view>
        </view>
      </view>
      <view class="meta-item">
        <text class="meta-icon">☀️</text>
        <view class="meta-content">
          <view class="meta-label">最佳季节</view>
          <view class="meta-value">{{place.bestSeason}} · 海拔 {{place.altitude}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 地点介绍卡片 -->
  <view class="content-card">
    <view class="card-header">
      <text class="card-icon">📝</text>
      <text class="card-title">地点介绍</text>
    </view>
    <view class="description-text">{{place.description}}</view>
  </view>

  <!-- 温馨提示卡片 -->
  <view class="content-card tips-card" wx:if="{{place.tipsList.length > 0}}">
    <view class="card-header">
      <text class="card-icon">💡</text>
      <text class="card-title">温馨提示</text>
    </view>
    <view class="tips-list">
      <view class="tip-item" wx:for="{{place.tipsList}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <!-- 行程列表 -->
  <view class="trip-section">
    <view class="section-header">
      <view class="section-title">
        <text>👥 想去的人</text>
        <!-- <view class="trip-count">{{trips.length}}</view> -->
      </view>
    </view>

    <view class="trip-list" wx:if="{{trips.length > 0}}">
      <view class="trip-item" wx:for="{{trips}}" wx:key="_id" bindtap="onTripTap" data-id="{{item._id}}">
        <!-- 顶部：头像+用户名+状态标签 | 操作按钮 -->
        <view class="trip-top">
          <view class="trip-user-info">
            <view class="user-avatar" style="background: {{item.avatarBg || 'linear-gradient(135deg, #4A90E2, #6BA3E8)'}}">
              <text>{{item.creatorName ? item.creatorName[0] : '旅'}}</text>
            </view>
            <text class="trip-user">{{item.creatorName || '旅行者'}}</text>
            <view class="trip-status {{item.hasCar ? 'has-car' : 'need-car'}}">
              <text>{{item.hasCar ? '有车' : '需拼车'}}</text>
            </view>
          </view>
          <view class="action-btn {{item.hasCar ? 'primary' : 'outline'}}" catchtap="onApplyTap" data-id="{{item._id}}" data-hascar="{{item.hasCar}}" data-username="{{item.creatorName}}">
            {{item.hasCar ? '申请加入' : '邀请他'}}
          </view>
        </view>

        <!-- 信息栏：出发日期 | 人数 -->
        <view class="trip-meta-row">
          <view class="trip-meta-item">
            <text class="trip-meta-label">出发</text>
            <text>{{item.date}}</text>
          </view>
          <view class="trip-meta-item">
            <text class="trip-meta-label">人数</text>
            <text>{{item.currentCount}}/{{item.currentCount + item.needCount}}人</text>
          </view>
        </view>

        <!-- 备注区域 -->
        <view class="trip-remark" wx:if="{{item.remark}}">{{item.remark}}</view>

        <!-- 底部：浏览量 + 发布时间 -->
        <view class="trip-footer">
          <view class="trip-footer-stats">
            <text class="trip-stat">👁 {{item.viewCount || 0}}次浏览</text>
            <text class="trip-stat">{{item.publishTime || '刚刚发布'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <view class="empty-icon">🏕️</view>
      <view class="empty-text">暂无行程，快来发布第一个吧！</view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>

<!-- 底部操作栏 -->
<view class="footer-bar">
  <view class="collect-btn {{isCollected ? 'collected' : ''}}" bindtap="onCollectTap">
    <text class="collect-icon">{{isCollected ? '❤️' : '🤍'}}</text>
    <text class="collect-text">{{isCollected ? '已收藏' : '收藏'}}</text>
  </view>
  <view class="publish-btn" bindtap="onPublishTrip">
    <text class="publish-icon">+</text>
    <text>发布我的行程</text>
  </view>
</view>

<!-- ========== 申请加入弹窗 ========== -->
<view class="modal-mask" wx:if="{{showApplyModal}}" bindtap="onCloseApplyModal">
  <view class="modal-content" catchtap="preventBubble">
    <view class="modal-header">
      <view class="modal-icon-wrap">
        <text class="modal-icon">🏔️</text>
      </view>
      <view class="modal-title">申请加入行程</view>
      <view class="modal-subtitle">{{place.name}} · 还剩{{currentTrip.needCount}}个名额</view>
    </view>

    <view class="modal-body">
      <!-- 联系方式类型 -->
      <view class="form-group">
        <view class="form-label">联系方式类型</view>
        <view class="contact-type-row">
          <view class="contact-type {{contactType === 'phone' ? 'active' : ''}}" catchtap="onSelectContactType" data-type="phone">
            <text>📱 手机号</text>
          </view>
          <view class="contact-type {{contactType === 'wechat' ? 'active' : ''}}" catchtap="onSelectContactType" data-type="wechat">
            <text>💬 微信号</text>
          </view>
        </view>
      </view>

      <!-- 联系方式输入 -->
      <view class="form-group">
        <view class="form-label">{{contactType === 'phone' ? '手机号码' : '微信号'}}</view>
        <input class="form-input" placeholder-class="input-placeholder" placeholder="{{contactType === 'phone' ? '请输入您的手机号' : '请输入您的微信号'}}" value="{{contactValue}}" bindinput="onContactInput" />
      </view>

      <!-- 自我介绍 -->
      <view class="form-group">
        <view class="form-label">自我介绍（选填）</view>
        <textarea class="form-textarea" placeholder="简单介绍一下自己..." value="{{introduction}}" bindinput="onIntroductionInput" />
      </view>
    </view>

    <view class="modal-footer">
      <view class="modal-btn modal-btn-cancel" catchtap="onCloseApplyModal">取消</view>
      <view class="modal-btn modal-btn-confirm" catchtap="onSubmitApply">提交申请</view>
    </view>
  </view>
</view>

<!-- ========== 邀请弹窗 ========== -->
<view class="modal-mask" wx:if="{{showInviteModal}}" bindtap="onCloseInviteModal">
  <view class="modal-content" catchtap="preventBubble">
    <view class="modal-header">
      <view class="modal-avatar" style="background: {{currentTrip.avatarBg}}">
        <text>{{currentTrip.userName[0]}}</text>
      </view>
      <view class="modal-title">邀请 {{currentTrip.userName}} 一起游玩</view>
      <view class="modal-subtitle">请留下您的联系方式</view>
    </view>

    <view class="modal-body">
      <!-- 联系方式类型 -->
      <view class="form-group">
        <view class="form-label">联系方式类型</view>
        <view class="contact-type-row">
          <view class="contact-type {{contactType === 'phone' ? 'active' : ''}}" catchtap="onSelectContactType" data-type="phone">
            <text>📱 手机号</text>
          </view>
          <view class="contact-type {{contactType === 'wechat' ? 'active' : ''}}" catchtap="onSelectContactType" data-type="wechat">
            <text>💬 微信号</text>
          </view>
        </view>
      </view>

      <!-- 联系方式输入 -->
      <view class="form-group">
        <view class="form-label">{{contactType === 'phone' ? '手机号码' : '微信号'}}</view>
        <input class="form-input" placeholder-class="input-placeholder" placeholder="{{contactType === 'phone' ? '请输入您的手机号' : '请输入您的微信号'}}" value="{{contactValue}}" bindinput="onContactInput" />
      </view>

      <!-- 留言 -->
      <view class="form-group">
        <view class="form-label">留言（选填）</view>
        <textarea class="form-textarea" placeholder="简单介绍一下自己或行程..." value="{{introduction}}" bindinput="onIntroductionInput" />
      </view>
    </view>

    <view class="modal-footer">
      <view class="modal-btn modal-btn-cancel" catchtap="onCloseInviteModal">取消</view>
      <view class="modal-btn modal-btn-confirm" catchtap="onSubmitInvite">发送邀请</view>
    </view>
  </view>
</view>
