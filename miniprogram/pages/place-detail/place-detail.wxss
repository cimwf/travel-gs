/* pages/place-detail/place-detail.wxss */
/* 严格按照设计稿实现 */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

page {
  background: var(--bg-color);
}

.container {
  padding-bottom: 160rpx;
  background: var(--bg-color);
}

/* ========== 顶部轮播图区域 ========== */
.header {
  position: relative;
  height: 440rpx;
  width: 100%;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

/* 渐变遮罩 */
.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0,0,0,0.3) 0%,
    rgba(0,0,0,0) 30%,
    rgba(0,0,0,0) 60%,
    rgba(0,0,0,0.6) 100%
  );
  pointer-events: none;
  z-index: 2;
}

/* 导航按钮 */
.nav-btn {
  position: absolute;
  top: 96rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  font-weight: 300;
  z-index: 10;
}

.nav-back {
  left: 32rpx;
}

.nav-share {
  right: 32rpx;
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* ========== 基本信息区域 ========== */
.info-section {
  width: 84%;
  background: white;
  margin: -50rpx 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
  z-index: 5;
  box-shadow: var(--shadow-md);
}

.place-header {
  margin-bottom: 32rpx;
}

.place-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.place-category {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.category-icon {
  font-size: 20rpx;
}

/* 数据指标 */
.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 标签 */
.tags-container {
  width: 84%;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(74, 144, 226, 0.08);
  color: var(--primary-color);
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 元信息 */
.meta-info {
  padding-top: 28rpx;
}

.meta-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.meta-content {
  flex: 1;
}

.meta-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* ========== 内容卡片 ========== */
.content-card {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 40rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.description-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  text-align: justify;
}

/* 温馨提示 */
.tips-card {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.08), rgba(250, 173, 20, 0.03));
  border-left: 6rpx solid var(--warning-color);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  position: relative;
  padding-left: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.tip-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--warning-color);
}

/* ========== 行程列表 ========== */
.trip-section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

.section-header {
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.trip-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.trip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.trip-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  background: var(--bg-color);
  border-radius: 24rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.trip-user {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.trip-status {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.trip-status.has-car {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.trip-status.need-car {
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
}

.trip-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.dot {
  color: var(--border-color);
}

.trip-remark {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: white;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  line-height: 1.5;
}

.btn-join {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.btn-primary {
  background: var(--primary-color);
  color: white;
}

.btn-outline {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========== 底部操作栏 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.collect-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
}

.collect-btn.collected .collect-text {
  color: var(--danger-color);
}

.collect-icon {
  font-size: 48rpx;
}

.collect-text {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.publish-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.4);
}

.publish-icon {
  font-size: 40rpx;
  font-weight: 300;
}
