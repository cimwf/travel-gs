/* pages/place-detail/place-detail.wxss */
/* 严格按照设计稿实现 */

page {
  background: #F5F7FA;
}

.container {
  padding-bottom: 140rpx;
  background: #F5F7FA;
}

/* ========== 顶部轮播图区域 ========== */
.header {
  position: relative;
  height: 480rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 轮播渐变背景 */
.banner-1 {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 50%, #2C5F8A 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 50%, #FFA07A 100%);
}

.banner-3 {
  background: linear-gradient(135deg, #56AB2F 0%, #A8E6CF 50%, #88D8B0 100%);
}

.banner-4 {
  background: linear-gradient(135deg, #2C3E50 0%, #4A4A68 50%, #6C7B95 100%);
}

/* 占位符内容 */
.banner-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.placeholder-icon {
  font-size: 120rpx;
  opacity: 0.9;
}

.placeholder-text {
  font-size: 32rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

/* 轮播指示点样式优化 */
.banner-swiper .wx-swiper-dots {
  bottom: 24rpx;
}

.banner-swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 50%;
  margin: 0 8rpx;
}

.banner-swiper .wx-swiper-dot-active {
  width: 36rpx;
  border-radius: 6rpx;
  background: white;
}

/* 渐变遮罩 - 按设计稿 */
.banner-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 25%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.5) 100%);
  pointer-events: none;
  z-index: 2;
}

/* 导航按钮 - 按设计稿 */
.nav-back, .nav-share {
  position: absolute;
  top: 96rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 300;
  z-index: 10;
}

.nav-back {
  left: 32rpx;
}

.nav-share {
  right: 32rpx;
}

/* ========== 基本信息区域 ========== */
.info-section {
  background: white;
  margin: -48rpx 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
  z-index: 5;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.12);
}

.place-header {
  margin-bottom: 32rpx;
}

.place-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.place-category {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 数据指标 - 四宫格 */
.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 32rpx 16rpx;
  border-bottom: 2rpx solid #E8E8F0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #8E8EA0;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #E8E8F0;
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 元信息 */
.meta-info {
  padding-top: 28rpx;
}

.meta-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.meta-content {
  flex: 1;
}

.meta-label {
  font-size: 22rpx;
  color: #8E8EA0;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #4A4A68;
  line-height: 1.4;
}

/* ========== 内容卡片 ========== */
.content-card {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.card-icon {
  font-size: 44rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* 地点介绍 */
.description-text {
  font-size: 28rpx;
  color: #4A4A68;
  line-height: 1.8;
  text-align: justify;
}

/* 温馨提示 */
.tips-card {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.08), rgba(250, 173, 20, 0.03));
  border-left: 6rpx solid #FAAD14;
}

.tips-list {
  font-size: 26rpx;
  color: #4A4A68;
  line-height: 1.8;
}

/* ========== 行程列表 ========== */
.trip-section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.trip-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 12rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 行程项 */
.trip-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.trip-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #F5F7FA;
  border-radius: 24rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.trip-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.trip-status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.trip-status.open {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.trip-status.full {
  background: #f0f0f0;
  color: #8E8EA0;
}

.trip-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8E8EA0;
  margin-bottom: 4rpx;
}

.trip-meta .dot {
  color: #D9D9D9;
}

.trip-remark {
  font-size: 24rpx;
  color: #4A4A68;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 加入按钮 */
.btn-join {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.3);
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8E8EA0;
}

/* ========== 底部操作栏 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.footer-left {
  margin-right: 32rpx;
}

.collect-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
}

.collect-btn.collected .collect-text {
  color: #FF4D4F;
}

.collect-icon {
  font-size: 52rpx;
}

.collect-text {
  font-size: 22rpx;
  color: #8E8EA0;
  margin-top: 4rpx;
}

.footer-right {
  flex: 1;
}

.publish-btn {
  width: 100%;
  padding: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.35);
}