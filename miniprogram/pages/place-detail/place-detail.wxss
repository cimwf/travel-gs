/* pages/place-detail/place-detail.wxss */
/* 严格按照设计稿实现 */

page {
  background: #F5F7FA;
}

.container {
  padding-bottom: 140rpx;
  background: #F5F7FA;
}

/* ========== 顶部轮播图区域 ========== */
.header {
  position: relative;
  height: 440rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 渐变遮罩 - 按设计稿 */
.banner-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 30%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.6) 100%);
  pointer-events: none;
  z-index: 2;
}

/* 导航按钮 - 按设计稿 */
.nav-back, .nav-share {
  position: absolute;
  top: 96rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  z-index: 10;
}

.nav-back {
  left: 32rpx;
}

.nav-share {
  right: 32rpx;
}

/* ========== 基本信息区域 ========== */
.info-section {
  background: white;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  position: relative;
  z-index: 5;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.place-header {
  margin-bottom: 32rpx;
}

.place-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.place-category {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 数据指标 - 四宫格 */
.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #E8E8F0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90E2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #8E8EA0;
}

/* 标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #E8E8F0;
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(74, 144, 226, 0.08);
  color: #4A90E2;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 元信息 */
.meta-info {
  padding-top: 32rpx;
}

.meta-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.meta-content {
  flex: 1;
}

.meta-label {
  font-size: 22rpx;
  color: #8E8EA0;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #4A4A68;
  line-height: 1.4;
}

/* ========== 内容卡片 ========== */
.content-card {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.card-icon {
  font-size: 48rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* 地点介绍 */
.description-text {
  font-size: 28rpx;
  color: #4A4A68;
  line-height: 1.8;
  text-align: justify;
}

/* 温馨提示 */
.tips-card {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.08), rgba(250, 173, 20, 0.03));
  border-left: 6rpx solid #FAAD14;
}

.tips-list {
  list-style: none;
}

.tips-list li {
  position: relative;
  padding-left: 32rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #4A4A68;
  line-height: 1.6;
}

.tips-list li:last-child {
  margin-bottom: 0;
}

/* ========== 行程列表 ========== */
.trip-section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.trip-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: #4A90E2;
  color: white;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 行程项 */
.trip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.trip-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  background: #F5F7FA;
  border-radius: 24rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.trip-info {
  flex: 1;
}

.trip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.trip-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.trip-status {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.trip-status.open {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.trip-status.full {
  background: #f5f5f5;
  color: #8E8EA0;
}

.trip-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #8E8EA0;
  margin-bottom: 8rpx;
}

.trip-meta .dot {
  color: #D9D9D9;
}

.trip-remark {
  font-size: 24rpx;
  color: #4A4A68;
  margin-top: 12rpx;
}

/* 加入按钮 */
.btn-join {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #8E8EA0;
}

/* ========== 底部操作栏 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.footer-left {
  margin-right: 32rpx;
}

.collect-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
}

.collect-btn.collected .collect-text {
  color: #FF4D4F;
}

.collect-icon {
  font-size: 48rpx;
}

.collect-text {
  font-size: 22rpx;
  color: #8E8EA0;
  margin-top: 4rpx;
}

.footer-right {
  flex: 1;
}

.publish-btn {
  width: 100%;
  padding: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.4);
}