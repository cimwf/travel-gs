/* pages/place-detail/place-detail.wxss */

page {
  background: #f5f7fa;
}

.container {
  padding-bottom: 140rpx;
  background: #f5f7fa;
}

/* ========== 顶部轮播图区域 ========== */
.header {
  position: relative;
  height: 440rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 渐变遮罩 */
.banner-mask-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(rgba(0,0,0,0.3), transparent);
  pointer-events: none;
}

.banner-mask-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.4));
  pointer-events: none;
}

/* 导航按钮 */
.nav-back, .nav-share {
  position: absolute;
  top: 40rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  z-index: 10;
}

.nav-back {
  left: 24rpx;
}

.nav-share {
  right: 24rpx;
}

/* ========== 基本信息区域 ========== */
.info-section {
  background: white;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  position: relative;
  z-index: 5;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.1);
}

.place-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.place-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.place-category {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #4A90E2, #667eea);
  color: white;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 四宫格数据 */
.data-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.data-item {
  text-align: center;
}

.data-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.data-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A90E2;
}

.data-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 标签 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 10rpx 20rpx;
  background: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 元信息 */
.meta-info {
  margin-top: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.meta-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.meta-text {
  flex: 1;
}

/* ========== 卡片区域 ========== */
.card-section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 温馨提示 */
.tips-section {
  background: rgba(245, 166, 35, 0.05);
  border-left: 6rpx solid #f5a623;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 行程列表 ========== */
.trip-section {
  background: white;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-count {
  font-size: 24rpx;
  color: #4A90E2;
  background: rgba(74, 144, 226, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 行程项 */
.trip-list {
  margin-top: 16rpx;
}

.trip-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.trip-item:last-child {
  border-bottom: none;
}

.trip-left {
  display: flex;
  flex: 1;
}

.trip-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin-right: 20rpx;
}

.trip-info {
  flex: 1;
}

.trip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.trip-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.trip-status {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.trip-status.open {
  background: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
}

.trip-status.full {
  background: #f5f5f5;
  color: #999;
}

.trip-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.trip-meta .dot {
  margin: 0 8rpx;
}

.trip-remark {
  font-size: 24rpx;
  color: #666;
  background: #f8f9fa;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

/* 加入按钮 */
.trip-action {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
}

.btn-join {
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #4A90E2, #667eea);
  color: white;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 底部操作栏 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.footer-left {
  margin-right: 20rpx;
}

.collect-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
}

.collect-btn.collected .collect-text {
  color: #ff4757;
}

.collect-icon {
  font-size: 40rpx;
}

.collect-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.footer-right {
  flex: 1;
}

.publish-btn {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #4A90E2, #667eea);
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.4);
}