/* pages/place-detail/place-detail.wxss */

.container {
  padding-bottom: 120rpx;
  background: var(--bg-color);
}

/* 头部 */
.header {
  position: relative;
  height: 400rpx;
}

.header-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: white;
}

.place-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.place-location {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 信息卡片 */
.info-card, .desc-card, .tips-card {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.info-item {
  text-align: center;
}

.info-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.info-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

.info-extra {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.extra-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.extra-label {
  color: var(--text-hint);
}

/* 描述 */
.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 提示 */
.tips-card {
  background: rgba(245, 166, 35, 0.05);
  border-left: 6rpx solid var(--warning-color);
}

.tips-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 行程列表 */
.trip-section {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.trip-list {
  margin-top: 20rpx;
}

.trip-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.trip-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin-right: 20rpx;
  overflow: hidden;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.trip-info {
  flex: 1;
}

.trip-user {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.trip-meta {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.trip-meta text {
  margin-right: 8rpx;
}

.trip-remark {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.trip-actions {
  margin-left: 20rpx;
}

.btn-apply, .btn-invite {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.btn-apply {
  background: var(--primary-color);
  color: white;
}

.btn-invite {
  background: white;
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: white;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
  gap: 20rpx;
}

.want-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 44rpx;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
  font-size: 28rpx;
}

.want-btn.wanted {
  background: rgba(74, 144, 226, 0.1);
}

.publish-btn {
  flex: 2;
  padding: 24rpx;
  text-align: center;
  border-radius: 44rpx;
  background: var(--primary-color);
  color: white;
  font-size: 28rpx;
  font-weight: 500;
}
