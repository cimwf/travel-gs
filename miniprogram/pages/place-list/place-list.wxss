/* pages/place-list/place-list.wxss */

page {
  --primary-color: #4A90E2;
  --text-primary: #1A1A2E;
  --text-secondary: #6B6B80;
  --text-hint: #A0A0B0;
  --bg-color: #F5F7FA;
  --border-color: #F0F0F5;
}

page {
  background: var(--bg-color);
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 20rpx 32rpx;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
}

.search-input {
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* ========== 列表区域 ========== */
.list-container {
  flex: 1;
  height: 0;
}

.place-list {
  padding: 20rpx 32rpx;
  margin-top: 0;
}

.place-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: white;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.place-item:active {
  background: #FAFAFC;
}

.place-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.place-cover-placeholder {
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.place-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.place-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.place-location {
  font-size: 24rpx;
  color: var(--text-hint);
}

.place-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  margin-left: 16rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========== 加载中 ========== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========== 自定义景点 ========== */
.custom-place {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  margin: 24rpx 32rpx 0;
  background: white;
  border-radius: 24rpx;
  border: 2rpx dashed var(--primary-color);
}

.custom-place:active {
  background: #FAFAFC;
}

.custom-icon {
  font-size: 36rpx;
}

.custom-text {
  font-size: 30rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.modal-body {
  padding: 40rpx 32rpx;
}

.custom-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
  font-size: 30rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.modal-btn-cancel {
  color: var(--text-hint);
  border-right: 1rpx solid var(--border-color);
}

.modal-btn-confirm {
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 上传景点 ========== */
.upload-spot-wrapper {
  width: 100%;
  background: white;
  padding-bottom: env(safe-area-inset-bottom);
}

.upload-spot-bar {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.upload-spot-bar:active {
  background: #FAFAFC;
}

.upload-spot-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.upload-spot-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--primary-color);
}

.upload-spot-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}
