<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatar || userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-text">
        <view class="nickname">{{userInfo.nickname || userInfo.nickName}}</view>
        <view class="edit-btn" bindtap="onEditProfile">点击编辑个人资料</view>
      </view>
    </view>
    <view class="login-prompt" wx:else bindtap="onLogin">
      <view class="avatar default-avatar">
        <image class="default-avatar-img" src="https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0" mode="aspectFill"></image>
      </view>
      <view class="user-text">
        <view class="nickname">点击登录</view>
        <view class="edit-btn">登录后查看更多功能</view>
      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <view class="stat-value">{{stats.published}}</view>
      <view class="stat-label">发布的行程</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{stats.wanted}}</view>
      <view class="stat-label">想去的地方</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value">{{stats.completed}}</view>
      <view class="stat-label">完成次数</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="key" data-key="{{item.key}}" bindtap="onMenuTap">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-text">{{item.text}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" wx:for="{{settingsList}}" wx:key="key" data-key="{{item.key}}" bindtap="onMenuTap">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-text">{{item.text}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>北京去哪玩 v1.0.0</text>
  </view>
</view>

<!-- 登录弹窗 -->
<login-modal show="{{showLoginModal}}" bind:close="onCloseLoginModal" bind:success="onLoginSuccess" />
