<!--
  我的页面 (profile)
  ================================
  设计稿：我的页面最终简洁版设计稿-v4.0.html - 方案G: 奶油杏
-->

<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header" style="padding-top: {{statusBarHeight + 20}}px;">
    <!-- 背景图片 -->
    <image class="profile-bg-image" src="{{userInfo.background || 'https://7072-prod-d2gkmbquec074b1df-1427058553.tcb.qcloud.la/attractions/1778050814136-42heznfom6q.JPG'}}" mode="aspectFill"></image>
    <!-- 渐变遮罩层 -->
    <view class="profile-bg-overlay"></view>

    <!-- 未登录状态 -->
    <view class="user-card" wx:if="{{!isLoggedIn}}" bindtap="onLogin">
      <view class="avatar">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-info">
        <view class="user-name">点击登录</view>
        <view class="user-id">登录后查看个人信息</view>
      </view>
    </view>

    <!-- 已登录状态 -->
    <view class="user-card" wx:else bindtap="onEditProfile">
      <image class="avatar-img" src="{{userInfo.avatar || userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatar || userInfo.avatarUrl}}"></image>
      <view class="avatar" wx:else>
        <text class="avatar-icon">{{userInfo.nickname ? userInfo.nickname[0] : '旅'}}</text>
      </view>
      <view class="user-info">
        <view class="user-name">{{userInfo.nickname || userInfo.nickName || '旅行者'}}</view>
        <view class="user-id">{{userInfo.bio || '喜欢户外运动，周末出游'}}</view>
      </view>
    </view>
  </view>

  <!-- 信息列表 -->
  <view class="info-list">

    <view class="info-bar" bindtap="onTapMyTrips">
      <view class="info-icon" style="background: linear-gradient(135deg, var(--primary-bg), var(--secondary-light));">📅</view>
      <view class="info-content">
        <view class="info-title">我的行程</view>
      </view>
      <text class="info-arrow">›</text>
    </view>

    <view class="info-bar" bindtap="onTapTripNotifications">
      <view class="info-icon" style="background: linear-gradient(135deg, var(--primary-bg), var(--accent-light));">🔔</view>
      <view class="info-content">
        <view class="info-title">行程通知</view>
      </view>
      <view class="info-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
      <text class="info-arrow">›</text>
    </view>

    <view class="info-bar" bindtap="onTapUploadSpot">
      <view class="info-icon" style="background: linear-gradient(135deg, var(--primary-bg), #E8D4C8);">📸</view>
      <view class="info-content">
        <view class="info-title">上传景点</view>
      </view>
      <text class="info-arrow">›</text>
    </view>

    <view class="info-bar ai-entry" bindtap="onTapAiImage">
      <view class="info-icon ai-icon">✨</view>
      <view class="info-content">
        <view class="info-title">AI 生图</view>
        <view class="info-desc">GPT Image 2 · 文生图 / 图生图</view>
      </view>
      <text class="info-arrow">›</text>
    </view>

    <view class="info-bar" bindtap="onTapFeedback">
      <view class="info-icon" style="background: linear-gradient(135deg, var(--primary-bg), var(--tertiary-light));">💡</view>
      <view class="info-content">
        <view class="info-title">提交建议</view>
      </view>
      <text class="info-arrow">›</text>
    </view>

    <view class="info-bar" bindtap="onTapAbout">
      <view class="info-icon" style="background: linear-gradient(135deg, var(--primary-bg), var(--primary-light));">ℹ️</view>
      <view class="info-content">
        <view class="info-title">关于我们</view>
      </view>
      <text class="info-arrow">›</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
