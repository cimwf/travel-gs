/* pages/profile/profile.wxss */

/* ========================================
   设计系统 - Design Token System
   ======================================== */
page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --primary-bg: rgba(74, 144, 226, 0.08);

  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;

  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  --border-color: #E8E8F0;
  --divider-color: #F0F0F5;

  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);

  --radius-lg: 24rpx;
  --radius-full: 9999rpx;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 40rpx;
}

/* 头部 */
.profile-header {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  padding: 80rpx 32rpx;
  color: white;
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.5);
}

.avatar-icon {
  font-size: 64rpx;
}

.user-text {
  flex: 1;
}

.login-hint {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 已登录状态 */
.logged-in {
  display: flex;
  flex-direction: column;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  margin-right: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.user-bio {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.user-tags {
  display: flex;
  gap: 12rpx;
}

.user-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
}

/* 统计数据 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  text-align: center;
  padding: 16rpx 32rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 菜单 */
.menu-section {
  background: white;
  margin: 24rpx 32rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-color);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 32rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #CCCCCC;
  font-size: 28rpx;
}
