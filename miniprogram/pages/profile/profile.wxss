/* pages/profile/profile.wxss */

/* ========================================
   北上周边行 - 我的页面设计规格
   设计稿：我的页面最终简洁版设计稿-v4.0.html
   配色：方案G - 奶油杏
   ======================================== */

page {
  /* 奶油杏配色方案 */
  --primary: #E8C4A0;
  --primary-light: #F2DCC4;
  --primary-bg: #FAF4ED;
  --accent: #D4A5A5;
  --accent-light: #EAD4D4;
  --secondary: #B8D4B8;
  --secondary-light: #D9E8D9;
  --tertiary: #C4B8D4;
  --tertiary-light: #E0D8E8;
  --bg: #F5F7FA;
  --text-primary: #4A4038;
  --text-secondary: #787068;
  --text-hint: #A89E94;
  --border: #F0E8DC;

  /* 禁止横向滚动 */
  overflow-x: hidden;
  background: var(--bg);
}

.container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg);
}

/* ========================================
   用户信息头部
   带背景图 + 渐变遮罩
   ======================================== */
.profile-header {
  width: 100%;
  padding: 120rpx 48rpx 80rpx;
  position: relative;
  overflow: hidden;
}

/* 背景图片 */
.profile-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 渐变遮罩层 */
.profile-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.3) 0%,
    rgba(0, 0, 0, 0.4) 50%,
    rgba(0, 0, 0, 0.5) 100%
  );
  z-index: 1;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  position: relative;
  z-index: 10;
}

/* 头像 */
.avatar {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), var(--accent-light));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
}

.avatar-img {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 64rpx;
}

/* 用户信息 */
.user-info {
  flex: 1;
  text-align: left;
}

.user-name {
  font-size: 44rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 12rpx;
  letter-spacing: 0.6rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.user-id {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 400;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ========================================
   信息列表
   ======================================== */
.info-list {
  width: 100%;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 信息条 */
.info-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 40rpx;
  background: white;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.info-bar:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 图标 */
.info-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
}

/* 内容 */
.info-content {
  flex: 1;
  text-align: left;
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 箭头 */
.info-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
}

/* 徽章 */
.info-badge {
  background: var(--accent);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-right: 8rpx;
}

/* ========================================
   底部安全区
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 80rpx);
}
