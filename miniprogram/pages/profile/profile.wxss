/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 头部 - 全屏宽度 */
.profile-header {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 80rpx 32rpx 120rpx;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.user-info, .login-prompt {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: white;
  margin-right: 32rpx;
  overflow: hidden;
  flex-shrink: 0;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
}

.default-avatar-img {
  width: 100%;
  height: 100%;
}

.user-text {
  color: white;
  flex: 1;
}

.nickname {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.edit-btn {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 统计栏 - 两侧留出边距 */
.stats-bar {
  display: flex;
  background: white;
  margin: -60rpx 32rpx 32rpx;
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  width: calc(100% - 64rpx);
  box-sizing: border-box;
  margin-left: 32rpx;
  margin-right: 32rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #4A90E2;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 16rpx;
}

.stat-divider {
  width: 1rpx;
  background: #EEEEEE;
  margin: 10rpx 0;
}

/* 菜单 - 两侧留出边距 */
.menu-section {
  background: white;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  width: calc(100% - 64rpx);
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 28rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #CCCCCC;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}
