/* pages/profile/profile.wxss */

/* ========================================
   北京去哪玩 - 我的页面设计规格
   设计稿：docs/design-spec.html
   ======================================== */

page {
  /* 主色 */
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;

  /* 文字颜色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  /* 背景与边框 */
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-color);
}

/* ========================================
   用户信息卡片
   背景: 渐变 primary → primary-dark
   padding: 24px 16px
   ======================================== */
.profile-header {
  width: 100%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  padding: 48rpx 32rpx;
  color: #FFFFFF;
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.5);
}

.avatar-icon {
  font-size: 64rpx;
}

.login-hint {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 已登录状态 */
.logged-in {
  display: flex;
  flex-direction: column;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.user-bio {
  font-size: 26rpx;
  opacity: 0.8;
  margin-bottom: 16rpx;
}

.user-tags {
  display: flex;
  gap: 16rpx;
}

.user-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 统计数据 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 32rpx;
  margin-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.menu-section-view {
  width: 100%;
  padding-left: 20rpx;
  padding-right: 20rpx;
}

/* ========================================
   功能入口
   背景: white, 圆角: 16px, margin: 16px
   菜单项: padding 16px, border-bottom 1px
   图标: 40px × 40px, 圆角10px
   ======================================== */
.menu-section {
  background: var(--card-bg);
  margin: 32rpx;
  border-radius: 32rpx;
  overflow: hidden;
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-color);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 60rpx 32rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}
