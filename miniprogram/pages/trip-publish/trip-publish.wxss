/* pages/trip-publish/trip-publish.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --text-primary: #1A1A2E;
  --text-secondary: #6B6B80;
  --text-hint: #A0A0B0;
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #F0F0F5;
  --danger-color: #EF4444;
}

page {
  background: white;
  width: 100%;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  width: 100%;
  background: white;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 表单内容区域 ========== */
.form-content {
  flex: 1;
  width: 100%;
  padding-bottom: 200rpx;
}

/* ========== 表格样式 ========== */
.form-table {
  width: 100%;
}

.table-row {
  display: flex;
  align-items: center;
  height: 100rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.table-row:last-child {
  border-bottom: none;
}

.table-picker {
  width: 100%;
}

.table-cell {
  height: 100%;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
}

.table-label {
  width: 200rpx;
  height: 100%;
  background: #FAFAFC;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
  flex-shrink: 0;
}

.table-value {
  flex: 1;
  justify-content: flex-end;
  font-size: 30rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.table-value.hint {
  color: var(--text-hint);
}

.table-input {
  flex: 1;
  padding: 0;
  border: none;
  font-size: 30rpx;
  background: transparent;
  color: var(--text-primary);
  text-align: right;
}

.table-input::placeholder {
  color: var(--text-hint);
}

.input-suffix {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.required {
  color: var(--danger-color);
  margin-left: 4rpx;
}

.arrow {
  margin-left: 16rpx;
  color: var(--text-hint);
  font-size: 32rpx;
}

/* ========== 分隔线 ========== */
.section-divider {
  height: 24rpx;
  background: var(--bg-color);
}

/* ========== 标签组 ========== */
.tag-group {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.tag-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--text-secondary);
  border: 1rpx solid rgba(74, 144, 226, 0.3);
}

.tag-btn.active {
  background: var(--primary-color);
  color: white;
  border-color: var(--primary-color);
}

/* ========== 数字选择器 ========== */
.counter-wrap {
  display: flex;
  align-items: center;
  gap: 28rpx;
  justify-content: flex-end;
}

.counter-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(74, 144, 226, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--primary-color);
}

.counter-btn:active {
  background: var(--primary-color);
  color: white;
}

.counter-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-width: 64rpx;
  text-align: center;
}

/* ========== 折叠区域 ========== */
.collapsible-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
}

.collapsible-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.collapsible-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  transition: transform 0.2s ease;
}

.collapsible-arrow.expanded {
  transform: rotate(180deg);
}

.collapsible-content {
  display: none;
}

.collapsible-content.expanded {
  display: block;
}

/* ========== 文本域 ========== */
.textarea-row {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  text-align: left;
}

.textarea-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
  text-align: left;
}

.textarea-field {
  width: 100%;
  height: 160rpx;
  border: none;
  font-size: 30rpx;
  background: transparent;
  resize: none;
  line-height: 1.6;
  color: var(--text-primary);
  text-align: left;
}

.textarea-field::placeholder {
  color: var(--text-hint);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 40rpx;
}

/* ========== 底部发布按钮 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 出发地选择弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.district-section {
  margin-bottom: 40rpx;
}

.district-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 24rpx;
}

.district-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  max-height: 640rpx;
  overflow-y: auto;
}

.district-item {
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.district-item.active {
  background: rgba(74, 144, 226, 0.15);
  color: var(--primary-color);
  font-weight: 500;
}

.modal-confirm {
  padding: 32rpx;
  background: var(--primary-color);
  color: white;
  text-align: center;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-confirm:active {
  opacity: 0.9;
}
