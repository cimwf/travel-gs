/* pages/trip-publish/trip-publish.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

page {
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  width: 100%;
  padding: 0 20rpx;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 24rpx;
  background: white;
  z-index: 100;
  border-bottom: 2rpx solid var(--border-color);
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.nav-placeholder {
  width: 72rpx;
}

.nav-placeholder-area {
  flex-shrink: 0;
}

/* ========== 表单内容区域 ========== */
.form-content {
  flex: 1;
  width: 100%;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* ========== 表单区块 ========== */
.form-section {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border-color);
}

/* ========== 表单项 ========== */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--bg-color);
}

.form-item.last-item {
  border-bottom: none;
  padding-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex-shrink: 0;
}

.form-value {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.value-text {
  font-size: 30rpx;
  color: var(--text-hint);
}

.placeholder-text {
  font-size: 30rpx;
  color: var(--text-hint);
}

.arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* ========== 单选按钮组 ========== */
.radio-group {
  display: flex;
  gap: 24rpx;
}

.radio-item {
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: var(--bg-color);
  color: var(--text-hint);
  transition: all 0.2s ease;
}

.radio-item.active {
  background: rgba(74, 144, 226, 0.15);
  color: var(--primary-color);
  font-weight: 500;
}

/* ========== 数字选择器 ========== */
.count-picker {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.count-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--text-hint);
  transition: all 0.2s ease;
}

.count-btn:active {
  background: var(--primary-color);
  color: white;
}

.count-value {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-width: 80rpx;
  text-align: center;
}

/* ========== 文本域 ========== */
.remark-input {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  background: #FAFAFA;
  box-sizing: border-box;
}

.remark-input::placeholder {
  color: var(--text-hint);
}

.char-count {
  text-align: right;
  font-size: 26rpx;
  color: var(--text-hint);
  margin-top: 16rpx;
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 40rpx;
}

/* ========== 底部发布按钮 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.4);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.submit-icon {
  font-size: 40rpx;
  font-weight: 300;
}

/* ========== 出发地选择弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.district-section {
  margin-bottom: 40rpx;
}

.district-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 24rpx;
}

.district-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  max-height: 640rpx;
  overflow-y: auto;
}

.district-item {
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.district-item.active {
  background: rgba(74, 144, 226, 0.15);
  color: var(--primary-color);
  font-weight: 500;
}

.modal-confirm {
  padding: 32rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  text-align: center;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.3);
}

.modal-confirm:active {
  opacity: 0.9;
}
