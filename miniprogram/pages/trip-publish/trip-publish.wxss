/* pages/trip-publish/trip-publish.wxss */

.container {
  padding: 32rpx;
  background: #F5F7FA;
  min-height: 100vh;
  padding-bottom: 160rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 表单区块 - 全屏宽度 */
.form-section {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  width: 100%;
  box-sizing: border-box;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  width: 100%;
  box-sizing: border-box;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

.form-value {
  display: flex;
  align-items: center;
  color: #666666;
  font-size: 30rpx;
}

.arrow {
  margin-left: 16rpx;
  color: #CCCCCC;
  font-size: 40rpx;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 24rpx;
}

.radio-item {
  padding: 18rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #F5F7FA;
  color: #666666;
  transition: all 0.2s ease;
}

.radio-item.active {
  background: rgba(74, 144, 226, 0.15);
  color: #4A90E2;
  font-weight: 500;
}

/* 数字选择器 */
.count-picker {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.count-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.count-btn:active {
  background: #4A90E2;
  color: white;
}

.count-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  min-width: 80rpx;
  text-align: center;
}

/* 文本域 */
.remark-input {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  background: #FAFAFA;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 26rpx;
  color: #999999;
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 48rpx;
  padding: 36rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: white;
  text-align: center;
  border-radius: 56rpx;
  font-size: 36rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.35);
}

.submit-btn:active {
  background: linear-gradient(135deg, #357ABD 0%, #2A6AA8 100%);
}
