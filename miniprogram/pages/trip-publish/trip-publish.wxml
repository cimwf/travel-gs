<!--pages/trip-publish/trip-publish.wxml-->
<view class="container">
  <!-- 表单内容 -->
  <view class="form-content">
    <!-- 行程标题 -->
    <view class="form-table">
      <view class="table-row">
        <view class="table-cell table-label">行程标题</view>
        <view class="table-cell table-value">
          <input class="table-input" placeholder="如：东灵山一日游" value="{{tripTitle}}" bindinput="onTitleInput" />
        </view>
      </view>
    </view>

    <view class="section-divider"></view>

    <!-- 目的地 -->
    <view class="form-table">
      <view class="table-row" bindtap="onSelectPlace">
        <view class="table-cell table-label">目的地<text class="required">*</text></view>
        <view class="table-cell table-value {{placeName ? '' : 'hint'}}">
          <text>{{placeName || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="section-divider"></view>

    <!-- 行程信息 -->
    <view class="form-table">
      <view class="table-row" bindtap="onSelectDeparture">
        <view class="table-cell table-label">出发地<text class="required">*</text></view>
        <view class="table-cell table-value {{departure ? '' : 'hint'}}">
          <text>{{departure || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="table-row">
        <view class="table-cell table-label">出行日期<text class="required">*</text></view>
        <picker class="table-picker" mode="date" value="{{date}}" start="{{minDate}}" bindchange="onDateChange">
          <view class="table-cell table-value {{date ? '' : 'hint'}}">
            <text>{{date || '请选择'}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="table-row">
        <view class="table-cell table-label">出行方式<text class="required">*</text></view>
        <view class="table-cell table-value">
          <view class="tag-group">
            <view class="tag-btn {{hasCar ? 'active' : ''}}" bindtap="onCarChange" data-value="{{true}}">有车</view>
            <view class="tag-btn {{!hasCar ? 'active' : ''}}" bindtap="onCarChange" data-value="{{false}}">无车</view>
          </view>
        </view>
      </view>
      <view class="table-row">
        <view class="table-cell table-label">招募人数<text class="required">*</text></view>
        <view class="table-cell table-value">
          <view class="counter-wrap">
            <view class="counter-btn" bindtap="onCountChange" data-type="minus">−</view>
            <text class="counter-num">{{recruitCount}}人</text>
            <view class="counter-btn" bindtap="onCountChange" data-type="plus">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-divider"></view>

    <!-- 手机号 -->
    <view class="form-table">
      <view class="table-row">
        <view class="table-cell table-label">手机号<text class="required">*</text></view>
        <view class="table-cell table-value">
          <input class="table-input" type="text" placeholder="同时也是微信号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        </view>
      </view>
    </view>

    <view class="section-divider"></view>

    <!-- 可选信息（折叠） -->
    <view class="collapsible-header" bindtap="toggleOptional">
      <text class="collapsible-title">可选信息</text>
      <text class="collapsible-arrow {{optionalExpanded ? 'expanded' : ''}}">▾</text>
    </view>
    <view class="collapsible-content {{optionalExpanded ? 'expanded' : ''}}">
      <view class="form-table">
        <view class="table-row">
          <view class="table-cell table-label">集合地点</view>
          <view class="table-cell table-value">
            <input class="table-input" placeholder="如：望京地铁站" value="{{meetingPlace}}" bindinput="onMeetingPlaceInput" />
          </view>
        </view>
        <view class="table-row">
          <view class="table-cell table-label">集合时间</view>
          <picker class="table-picker" mode="time" value="{{meetingTime}}" bindchange="onMeetingTimeChange">
            <view class="table-cell table-value {{meetingTime ? '' : 'hint'}}">
              <text>{{meetingTime || '请选择'}}</text>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>
        <!-- 有车时显示车辆座位和车型 -->
        <view class="table-row" wx:if="{{hasCar}}">
          <view class="table-cell table-label">车辆座位</view>
          <view class="table-cell table-value">
            <input class="table-input" placeholder="如：5座" value="{{carSeats}}" bindinput="onCarSeatsInput" />
          </view>
        </view>
        <view class="table-row" wx:if="{{hasCar}}">
          <view class="table-cell table-label">车辆型号</view>
          <view class="table-cell table-value">
            <input class="table-input" placeholder="如：商务车" value="{{carModel}}" bindinput="onCarModelInput" />
          </view>
        </view>
        <!-- 无车时显示出行描述 -->
        <view class="table-row" wx:if="{{!hasCar}}">
          <view class="table-cell table-label">出行描述</view>
          <view class="table-cell table-value">
            <input class="table-input" placeholder="如：地铁+公交（10字内）" value="{{travelDesc}}" bindinput="onTravelDescInput" maxlength="10" />
          </view>
        </view>
        <view class="table-row">
          <view class="table-cell table-label">人均价格</view>
          <view class="table-cell table-value">
            <input class="table-input" placeholder="如：150元/人" value="{{price}}" bindinput="onPriceInput" />
          </view>
        </view>
      </view>
      <!-- 行程说明 -->
      <view class="textarea-row">
        <text class="textarea-label">行程说明</text>
        <textarea class="textarea-field" placeholder="描述行程安排、费用分摊方式、对同伴的要求等" value="{{remark}}" bindinput="onRemarkInput" maxlength="200"></textarea>
        <view class="char-count">{{remark.length}}/200</view>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>

<!-- 底部发布按钮 -->
<view class="footer-bar">
  <view class="submit-btn" bindtap="onSubmit">发布行程</view>
</view>

<!-- ========== 出发地选择弹窗 ========== -->
<view class="modal-mask" wx:if="{{showDepartureModal}}" bindtap="onCloseDepartureModal">
  <view class="modal-content" catchtap="">
    <view class="modal-header">
      <view class="modal-title">选择出发地</view>
      <view class="modal-close" bindtap="onCloseDepartureModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="district-section">
      <view class="district-subtitle">选择区（北京 · 共16个区）</view>
      <view class="district-grid">
        <view class="district-item {{tempDeparture === item ? 'active' : ''}}" wx:for="{{districts}}" wx:key="*this" bindtap="onSelectDistrict" data-district="{{item}}">{{item}}</view>
      </view>
    </view>
    <view class="modal-confirm" bindtap="onConfirmDeparture">确认选择</view>
  </view>
</view>
