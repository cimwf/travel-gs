<!--pages/my-trips/my-trips.wxml-->
<view class="container">
  <!-- 标签切换 -->
  <view class="tabs-container">
    <view class="tabs">
      <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="onTabChange" data-tab="all">全部</view>
      <view class="tab {{activeTab === 'created' ? 'active' : ''}}" bindtap="onTabChange" data-tab="created">我发起的</view>
      <view class="tab {{activeTab === 'joined' ? 'active' : ''}}" bindtap="onTabChange" data-tab="joined">我参与的</view>
      <view class="tab {{activeTab === 'ended' ? 'active' : ''}}" bindtap="onTabChange" data-tab="ended">已结束</view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 行程列表 -->
    <block wx:if="{{trips.length > 0}}">
      <view class="trip-card" wx:for="{{trips}}" wx:key="_id" bindtap="onTripTap" data-id="{{item._id}}">
        <!-- 卡片头部 -->
        <view class="trip-header">
          <view class="trip-img" style="background: {{item.imgBg}};">
            <image wx:if="{{item.placeCoverImage}}" class="trip-cover" src="{{item.placeCoverImage}}" mode="aspectFill"></image>
            <text wx:else class="trip-emoji">{{item.emoji}}</text>
          </view>
          <view class="trip-info">
            <view class="trip-name">{{item.placeName}}</view>
            <view class="trip-date">📅 {{item.dateText}}</view>
            <view class="trip-count">👥 已{{item.currentCount}}人 · {{item.needCount > 0 ? '还需' + item.needCount + '人' : '已满员'}}</view>
          </view>
          <view class="trip-status status-{{item.statusClass}}">{{item.statusText}}</view>
        </view>

        <!-- 参与者 -->
        <view class="trip-participants">
          <block wx:for="{{item.participants}}" wx:for-item="p" wx:for-index="pIndex" wx:key="userId">
            <image class="participant-avatar {{pIndex === 0 ? 'participant-creator' : ''}}" src="{{p.avatar}}" wx:if="{{p.avatar}}" mode="aspectFill"></image>
            <view class="participant {{pIndex === 0 ? 'participant-creator' : ''}}" wx:else>
              <text>{{p.nickname ? p.nickname[0] : '旅'}}</text>
            </view>
          </block>
        </view>

        <!-- 操作按钮 -->
        <view class="trip-actions" wx:if="{{activeTab !== 'ended'}}">
          <view class="action-btn secondary" wx:if="{{item.isCreator}}" catchtap="onManageTap" data-id="{{item._id}}">管理</view>
          <view class="action-btn secondary" wx:if="{{!item.isCreator && activeTab === 'joined'}}" catchtap="onQuitTap" data-id="{{item._id}}">退出</view>
          <view class="action-btn primary" catchtap="onDetailTap" data-id="{{item._id}}">查看详情</view>
        </view>
        <view class="trip-actions" wx:else>
          <view class="action-btn secondary" wx:if="{{item.isCreator}}" catchtap="onManageTap" data-id="{{item._id}}">管理</view>
          <view class="action-btn primary" catchtap="onDetailTap" data-id="{{item._id}}">查看详情</view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{trips.length === 0 && !loading}}">
      <view class="empty-icon">{{emptyIcon}}</view>
      <view class="empty-title">{{emptyTitle}}</view>
      <view class="empty-desc">{{emptyDesc}}</view>
      <view class="empty-btn" bindtap="onExploreTap">发现周边好去处</view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>

<!-- 悬浮发布按钮 -->
<!-- <view class="fab" bindtap="onPublishTap">
  <text class="fab-icon">+</text>
</view> -->

<!-- 管理弹窗 -->
<view class="manage-modal-mask" wx:if="{{showManageModal}}" bindtap="onCloseManageModal">
  <view class="manage-modal" catchtap="">
    <view class="manage-modal-header">
      <text class="manage-modal-title">管理行程</text>
      <view class="manage-modal-close" bindtap="onCloseManageModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="manage-modal-content">
      <view class="manage-trip-info" wx:if="{{manageTrip}}">
        <text class="manage-trip-name">{{manageTrip.placeName}}</text>
        <text class="manage-trip-date">📅 {{manageTrip.dateText}}</text>
      </view>
      <view class="manage-actions">
        <view class="manage-action" bindtap="onEditTrip">
          <text class="manage-action-icon">✏️</text>
          <text class="manage-action-text">编辑行程</text>
        </view>
        <view class="manage-action" bindtap="onStopRecruit" wx:if="{{manageTrip && manageTrip.rawStatus !== 'stopped'}}">
          <text class="manage-action-icon">⏸️</text>
          <text class="manage-action-text">停止招募</text>
        </view>
        <view class="manage-action" bindtap="onStartRecruit" wx:if="{{manageTrip && manageTrip.rawStatus === 'stopped'}}">
          <text class="manage-action-icon">▶️</text>
          <text class="manage-action-text">开始招募</text>
        </view>
        <view class="manage-action" bindtap="onShareTrip">
          <text class="manage-action-icon">📤</text>
          <text class="manage-action-text">分享行程</text>
        </view>
        <view class="manage-action" bindtap="onCancelTrip" wx:if="{{manageTrip && manageTrip.rawStatus !== 'cancelled'}}">
          <text class="manage-action-icon">❌</text>
          <text class="manage-action-text">取消行程</text>
        </view>
        <view class="manage-action danger" bindtap="onDeleteTrip">
          <text class="manage-action-icon">🗑️</text>
          <text class="manage-action-text">删除行程</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 分享弹窗 -->
<view class="share-modal-mask" wx:if="{{showShareModal}}" bindtap="onCloseShareModal">
  <view class="share-modal" catchtap="">
    <view class="share-modal-header">
      <text class="share-modal-title">分享行程</text>
      <view class="share-modal-close" bindtap="onCloseShareModal">
        <text class="close-icon">×</text>
      </view>
    </view>
    <view class="share-modal-content" wx:if="{{shareTrip}}">
      <view class="share-trip-info">
        <text class="share-trip-name">{{shareTrip.placeName}}</text>
        <text class="share-trip-date">📅 {{shareTrip.dateText}}</text>
      </view>
      <view class="share-tip">点击下方按钮分享给微信好友</view>
    </view>
    <view class="share-modal-footer">
      <button class="share-btn" open-type="share" data-trip="{{shareTrip}}">
        <text class="share-btn-icon">📤</text>
        <text>分享给好友</text>
      </button>
    </view>
  </view>
</view>
