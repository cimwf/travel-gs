/* pages/my-trips/my-trips.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --success-color: #52C41A;
  --warning-color: #FA8C16;
  --danger-color: #FF4D4F;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 标签切换 ========== */
.tabs-container {
  width: 100%;
  background: white;
  padding: 24rpx;
  border-bottom: 2rpx solid #F0F0F5;
}

.tabs {
  display: flex;
  gap: 16rpx;
}

.tab {
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.tab.active {
  background: var(--primary-color);
  color: white;
}

.tab:not(.active) {
  background: var(--bg-color);
  color: var(--text-secondary);
}


/* ========== 内容区域 ========== */
.content {
  width: 100%;
  flex: 1;
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ========== 行程卡片 ========== */
.trip-card {
  width: 100%;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.trip-header {
  display: flex;
  padding: 32rpx;
  gap: 24rpx;
}

.trip-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.trip-cover {
  width: 100%;
  height: 100%;
}

.trip-emoji {
  font-size: 72rpx;
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.trip-date {
  font-size: 28rpx;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.trip-count {
  font-size: 26rpx;
  color: var(--text-hint);
}

.trip-status {
  padding: 0rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
  height: 50rpx;
  line-height: 50rpx;
}

.status-open {
  background: #E8F5E9;
  color: var(--success-color);
}

.status-full {
  background: #FFF3E0;
  color: var(--warning-color);
}

.status-ended {
  background: #F5F5F5;
  color: var(--text-hint);
}

.status-stopped {
  background: #FFEBEE;
  color: #E53935;
}

.status-cancelled {
  background: #F5F5F5;
  color: var(--text-hint);
}

/* ========== 参与者 ========== */
.trip-participants {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #F0F0F5;
  gap: 16rpx;
}

.participant {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  margin-left: -16rpx;
  border: 4rpx solid white;
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-left: -16rpx;
  border: 4rpx solid white;
}

.participant:first-child {
  margin-left: 0;
}

.participant-avatar:first-child {
  margin-left: 0;
}

.participant-creator {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border: 4rpx solid white;
}

/* ========== 操作按钮 ========== */
.trip-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #F0F0F5;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: var(--primary-color);
  color: white;
}

.action-btn.secondary {
  background: var(--bg-color);
  color: var(--text-secondary);
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 120rpx 80rpx;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 48rpx;
}

.empty-btn {
  display: inline-block;
  padding: 24rpx 64rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  height: 40rpx;
}

/* ========== 悬浮发布按钮 ========== */
.fab {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.4);
  z-index: 100;
}

.fab:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: white;
  font-weight: 300;
}

/* ========== 分享弹窗 ========== */
.share-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-modal {
  width: 600rpx;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.share-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.share-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.share-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-modal-content {
  padding: 40rpx 32rpx;
}

.share-trip-info {
  text-align: center;
  margin-bottom: 24rpx;
}

.share-trip-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.share-trip-date {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.share-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-hint);
}

.share-modal-footer {
  padding: 24rpx 32rpx 40rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 28rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.share-btn::after {
  border: none;
}

.share-btn-icon {
  font-size: 36rpx;
}

/* ========== 管理弹窗 ========== */
.manage-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.manage-modal {
  width: 600rpx;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.manage-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.manage-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.manage-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: var(--text-hint);
}

.manage-modal-content {
  padding: 32rpx;
}

.manage-trip-info {
  text-align: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.manage-trip-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.manage-trip-date {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.manage-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.manage-action {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  background: var(--bg-color);
  border-radius: 24rpx;
}

.manage-action:active {
  opacity: 0.8;
}

.manage-action.danger {
  background: #FFF1F0;
}

.manage-action.danger .manage-action-text {
  color: var(--danger-color);
}

.manage-action-icon {
  font-size: 36rpx;
}

.manage-action-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}
