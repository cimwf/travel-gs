<view class="ai-page">
  <view class="bg">
    <view class="circle c1"></view>
    <view class="circle c2"></view>
  </view>

  <view class="hero">
    <view class="hero-kicker">GPT Image 2</view>
    <view class="hero-title">最强大的 AI 生图模型</view>
    <view class="hero-desc">支持文生图与图生图，把旅行灵感、头像、海报和路线封面快速变成可用图片。</view>
    <view class="hero-tags">
      <text>高清细节</text>
      <text>中文提示词</text>
      <text>参考图改造</text>
    </view>
  </view>

  <view class="quota-panel" bindtap="onOpenGallery">
    <view>
      <view class="quota-title">我的 AI 作品</view>
      <view class="quota-desc" wx:if="{{summaryReady}}">已生成 {{summary.generatedCount}} 张 · 剩余 {{summary.remaining}} / {{summary.total}} 次</view>
      <view class="quota-desc" wx:else>额度读取中...</view>
    </view>
    <view class="quota-button">查看</view>
  </view>

  <view class="mode-tabs">
    <view class="mode-tab {{mode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="onSwitchMode">文生图</view>
    <view class="mode-tab {{mode === 'image' ? 'active' : ''}}" data-mode="image" bindtap="onSwitchMode">图生图</view>
  </view>

  <view class="panel">
    <view class="section-head">
      <view>
        <view class="section-title">创作描述</view>
        <view class="section-tip" wx:if="{{mode === 'image'}}">图生图可只上传参考图，描述可选。</view>
      </view>
      <view class="section-action" bindtap="onOpenTemplateLibrary">更多模板</view>
    </view>
    <textarea
      class="prompt-input"
      placeholder="{{mode === 'text' ? '描述你想生成的画面，例如：冬日长城脚下的露营海报，暖色灯光，电影感...' : '选填：描述希望如何改造参考图，例如：保留人物姿态，换成北方雪山旅行海报风格...'}}"
      placeholder-class="placeholder"
      maxlength="500"
      value="{{prompt}}"
      bindinput="onPromptInput"
    ></textarea>
    <view class="input-meta">{{prompt.length}}/500</view>
    <view class="template-block" wx:if="{{quickTemplates.length}}">
      <view class="template-head">
        <view class="template-title">{{mode === 'image' ? '图生图快捷模板' : '热门创作模板'}}</view>
        <view class="template-more" bindtap="onOpenTemplateLibrary">更多</view>
      </view>
      <view class="template-grid">
        <view class="template-card" wx:for="{{quickTemplates}}" wx:key="_id" data-template="{{item}}" bindtap="onUseTemplate">
          <view class="template-card-top">
            <text class="template-badge">{{item.badge}}</text>
            <text class="template-ratio">{{item.ratio}}</text>
          </view>
          <view class="template-name">{{item.title}}</view>
          <view class="template-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="panel" wx:if="{{mode === 'image'}}">
    <view class="section-head">
      <view class="section-title">参考图片</view>
      <view class="section-action" bindtap="onChooseImage">{{referenceImage ? '更换' : '上传'}}</view>
    </view>
    <view class="upload-box" bindtap="onChooseImage">
      <image wx:if="{{referenceImage}}" class="reference-image" src="{{referenceImage}}" mode="aspectFill"></image>
      <view wx:else class="upload-empty">
        <view class="upload-mark">+</view>
        <view class="upload-text">选择一张图片作为生成参考</view>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">生成设置</view>
    <view class="option-group">
      <view class="option-label">画面比例</view>
      <view class="chips">
        <view class="chip {{ratio === item ? 'selected' : ''}}" wx:for="{{ratios}}" wx:key="*this" data-value="{{item}}" bindtap="onSelectRatio">{{item}}</view>
      </view>
    </view>
    <view class="option-group">
      <view class="option-label">视觉风格</view>
      <view class="chips">
        <view class="chip {{style === item.value ? 'selected' : ''}}" wx:for="{{styles}}" wx:key="value" data-value="{{item.value}}" bindtap="onSelectStyle">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="bottom-actions">
      <view class="channel-btn" bindtap="onOpenChannelPicker">
        <view class="channel-btn-name">{{selectedChannel ? selectedChannel.name : (channelLoading ? '加载中...' : '默认渠道')}}</view>
      </view>
      <view class="generate-btn {{canGenerate ? '' : 'disabled'}}" bindtap="onGenerate">
        {{loading ? '正在提交...' : (mode === 'text' ? '用文字生成图片' : '用参考图生成图片')}}
      </view>
    </view>
  </view>

  <view class="channel-mask" wx:if="{{showChannelPicker}}" catchtap="closeChannelPicker">
    <view class="channel-modal" catchtap="noop">
      <view class="channel-modal-title">选择渠道</view>
      <view class="channel-list" wx:if="{{channels.length}}">
        <view
          class="channel-item {{selectedChannelId === item.channelId ? 'active' : ''}}"
          wx:for="{{channels}}"
          wx:key="channelId"
          data-id="{{item.channelId}}"
          bindtap="onSelectChannel"
        >
          <view class="channel-item-main">
            <view class="channel-item-name">{{item.name}}</view>
          </view>
        </view>
      </view>
      <view class="channel-empty" wx:else>暂无可用渠道</view>
      <view class="channel-cancel" bindtap="closeChannelPicker">取消</view>
    </view>
  </view>

  <view class="package-mask" wx:if="{{showPackageModal}}" catchtap="closePackageModal">
    <view class="package-modal" catchtap="noop">
      <view class="package-title">AI 生图次数已用完</view>
      <view class="package-desc" wx:if="{{summaryReady}}">当前剩余 {{summary.remaining}} 次，选择套餐后会立即充值到账户。</view>
      <view class="package-desc" wx:else>正在读取账户额度，选择套餐后会立即充值到账户。</view>
      <view class="package-list" wx:if="{{packages.length}}">
        <view class="package-card" wx:for="{{packages}}" wx:key="_id">
          <view class="package-info">
            <view class="package-card-title">{{item.title}}</view>
            <view class="package-card-desc">{{item.desc}}</view>
            <view class="package-card-desc">可生成 {{item.imageCount}} 张图</view>
            <view class="package-meta">
              <view class="package-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
              <view class="package-discount" wx:if="{{item.discountText}}">{{item.discountText}}</view>
            </view>
          </view>
          <view class="package-buy">
            <view class="package-price-label" wx:if="{{item.hasDiscount}}">折后价</view>
            <view class="package-price">¥{{item.priceText}}</view>
            <view class="package-original-price" wx:if="{{item.hasDiscount}}">折前价 ¥{{item.originalPriceText}}</view>
            <view class="package-button" data-id="{{item._id || item.id}}" bindtap="onPurchasePackage">
              {{purchasingPackageId === (item._id || item.id) ? '充值中' : '支付'}}
            </view>
          </view>
        </view>
      </view>
      <view class="package-empty" wx:else>
        {{packageLoading ? '套餐加载中...' : '暂无可购买套餐，请稍后再试'}}
      </view>
      <view class="package-cancel" bindtap="closePackageModal">暂不充值</view>
    </view>
  </view>
</view>
