<view class="ai-page">
  <view class="bg">
    <view class="circle c1"></view>
    <view class="circle c2"></view>
  </view>

  <view class="hero">
    <view class="hero-kicker">GPT Image 2</view>
    <view class="hero-title">最强大的 AI 生图模型</view>
    <view class="hero-desc">支持文生图与图生图，把旅行灵感、头像、海报和路线封面快速变成可用图片。</view>
    <view class="hero-tags">
      <text>高清细节</text>
      <text>中文提示词</text>
      <text>参考图改造</text>
    </view>
  </view>

  <view class="view-tabs">
    <view class="view-tab {{activeView === 'create' ? 'active' : ''}}" bindtap="onBackToCreate">创作</view>
    <view class="view-tab {{activeView === 'gallery' ? 'active' : ''}}" bindtap="onOpenGallery">作品集</view>
  </view>

  <view class="quota-panel" bindtap="onOpenGallery">
    <view>
      <view class="quota-title">我的 AI 作品</view>
      <view class="quota-desc">已生成 {{summary.generatedCount}} 张 · 剩余 {{summary.remaining}} / {{summary.total}} 次</view>
    </view>
    <view class="quota-button">{{activeView === 'gallery' ? '刷新' : '查看'}}</view>
  </view>

  <block wx:if="{{activeView === 'create'}}">
    <view class="mode-tabs">
      <view class="mode-tab {{mode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="onSwitchMode">文生图</view>
      <view class="mode-tab {{mode === 'image' ? 'active' : ''}}" data-mode="image" bindtap="onSwitchMode">图生图</view>
    </view>

    <view class="panel">
      <view class="section-title">创作描述</view>
      <view class="section-tip" wx:if="{{mode === 'image'}}">图生图可只上传参考图，描述可选。</view>
      <textarea
        class="prompt-input"
        placeholder="{{mode === 'text' ? '描述你想生成的画面，例如：冬日长城脚下的露营海报，暖色灯光，电影感...' : '选填：描述希望如何改造参考图，例如：保留人物姿态，换成北方雪山旅行海报风格...'}}"
        placeholder-class="placeholder"
        maxlength="500"
        value="{{prompt}}"
        bindinput="onPromptInput"
      ></textarea>
      <view class="input-meta">{{prompt.length}}/500</view>
    </view>

    <view class="panel" wx:if="{{mode === 'image'}}">
      <view class="section-head">
        <view class="section-title">参考图片</view>
        <view class="section-action" bindtap="onChooseImage">{{referenceImage ? '更换' : '上传'}}</view>
      </view>
      <view class="upload-box" bindtap="onChooseImage">
        <image wx:if="{{referenceImage}}" class="reference-image" src="{{referenceImage}}" mode="aspectFill"></image>
        <view wx:else class="upload-empty">
          <view class="upload-mark">+</view>
          <view class="upload-text">选择一张图片作为生成参考</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="section-title">生成设置</view>
      <view class="option-group">
        <view class="option-label">画面比例</view>
        <view class="chips">
          <view class="chip {{ratio === item ? 'selected' : ''}}" wx:for="{{ratios}}" wx:key="*this" data-value="{{item}}" bindtap="onSelectRatio">{{item}}</view>
        </view>
      </view>
      <view class="option-group">
        <view class="option-label">视觉风格</view>
        <view class="chips">
          <view class="chip {{style === item ? 'selected' : ''}}" wx:for="{{styles}}" wx:key="*this" data-value="{{item}}" bindtap="onSelectStyle">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="bottom-bar">
      <view class="generate-btn {{canGenerate ? '' : 'disabled'}}" bindtap="onGenerate">
        {{loading ? '正在提交...' : (mode === 'text' ? '用文字生成图片' : '用参考图生成图片')}}
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="gallery-head">
      <view>
        <view class="gallery-title">作品集</view>
        <view class="gallery-desc">最新生成的图片会显示在最上方。</view>
      </view>
      <view class="refresh-btn" bindtap="loadWorks">{{galleryLoading ? '刷新中' : '刷新'}}</view>
    </view>

    <view class="empty" wx:if="{{isGalleryEmpty && !galleryLoading}}">
      <view class="empty-icon">+</view>
      <view class="empty-title">还没有 AI 作品</view>
      <view class="empty-desc">提交生成后，任务和结果会按最新时间显示在这里。</view>
    </view>

    <view class="image-list" wx:else>
      <view class="image-card" wx:for="{{works}}" wx:key="_id">
        <view class="image-wrap {{item.status !== 'completed' ? 'pending' : ''}}">
          <block wx:if="{{item.status === 'completed' && item.imageUrl}}">
            <image class="work-image" src="{{item.imageUrl}}" mode="aspectFill" data-url="{{item.imageUrl}}" bindtap="onPreviewImage"></image>
          </block>
          <block wx:elif="{{item.status === 'failed' || item.status === 'cancelled'}}">
            <view class="failed-box">
              <view class="failed-mark">!</view>
              <view class="status-title">生成失败</view>
              <view class="status-desc">{{item.errorText}}</view>
            </view>
          </block>
          <block wx:else>
            <view class="skeleton-box">
              <view class="skeleton-image"></view>
              <view class="skeleton-line short"></view>
              <view class="skeleton-line"></view>
              <view class="status-title">生成中</view>
              <view class="status-desc">高清图片正在生成，请稍后刷新</view>
            </view>
          </block>
        </view>
        <view class="card-body">
          <view class="meta-row">
            <text>{{item.mode === 'image' ? '图生图' : '文生图'}}</text>
            <text>{{item.style}}</text>
            <text>{{item.ratio}}</text>
            <text>{{item.statusText}}</text>
          </view>
          <view class="prompt">{{item.prompt || '基于参考图生成'}}</view>
          <view class="image-meta" wx:if="{{item.metaText}}">{{item.metaText}}</view>
          <view class="time-text" wx:if="{{item.createdText}}">{{item.createdText}}</view>
          <view class="actions" wx:if="{{item.status === 'completed' && item.imageUrl}}">
            <view class="action primary" data-url="{{item.imageUrl}}" bindtap="onSaveImage">保存</view>
            <view class="action" data-url="{{item.imageUrl}}" bindtap="onPreviewImage">放大</view>
            <view class="action" data-url="{{item.copyUrl}}" bindtap="onCopyLink">复制链接</view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
