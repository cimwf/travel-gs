page {
  background: #F6F7FB;
  color: #182033;
}

.container {
  min-height: 100vh;
  padding: 28rpx 28rpx 180rpx;
  box-sizing: border-box;
  background: #F6F7FB;
}

.hero {
  padding: 44rpx 36rpx 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #111827 0%, #27435E 52%, #F0B96D 100%);
  color: #FFFFFF;
  overflow: hidden;
  position: relative;
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  bottom: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.hero-kicker {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 24rpx;
  max-width: 560rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.hero-desc {
  margin-top: 18rpx;
  max-width: 600rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.86);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-tags text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  font-size: 22rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
  margin: 28rpx 0;
  padding: 8rpx;
  border-radius: 22rpx;
  background: #E9EDF5;
}

.mode-tab {
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 28rpx;
  font-weight: 700;
}

.mode-tab.active {
  background: #FFFFFF;
  color: #182033;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.08);
}

.panel,
.preview-panel {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(17, 24, 39, 0.05);
}

.section-head,
.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #182033;
}

.section-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #2F80ED;
  font-size: 24rpx;
  font-weight: 700;
}

.prompt-input {
  width: 100%;
  min-height: 220rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #F6F7FB;
  color: #182033;
  font-size: 28rpx;
  line-height: 1.55;
}

.placeholder {
  color: #9AA4B2;
}

.input-meta {
  margin-top: 12rpx;
  text-align: right;
  color: #98A2B3;
  font-size: 22rpx;
}

.upload-box {
  height: 360rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
  background: #F6F7FB;
  border: 2rpx dashed #C9D2E3;
  overflow: hidden;
}

.reference-image {
  width: 100%;
  height: 100%;
}

.upload-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #667085;
}

.upload-mark {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2F80ED;
  font-size: 54rpx;
  font-weight: 300;
}

.upload-text {
  font-size: 26rpx;
}

.option-group {
  margin-top: 26rpx;
}

.option-label {
  margin-bottom: 16rpx;
  color: #667085;
  font-size: 25rpx;
  font-weight: 700;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-width: 112rpx;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #F1F4F9;
  color: #4B5565;
  text-align: center;
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.chip.selected {
  background: #182033;
  color: #FFFFFF;
}

.preview-subtitle {
  margin-top: 8rpx;
  color: #98A2B3;
  font-size: 23rpx;
  line-height: 1.4;
}

.model-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #FFF2DA;
  color: #9A5B00;
  font-size: 22rpx;
  font-weight: 800;
}

.preview-canvas {
  height: 430rpx;
  margin-top: 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #E9F5FF 0%, #FFF7E8 100%);
  position: relative;
  overflow: hidden;
}

.result-image {
  width: 100%;
  height: 100%;
  background: #111827;
}

.preview-glow {
  position: absolute;
  inset: 34rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.28);
}

.preview-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #475467;
}

.preview-icon {
  font-size: 70rpx;
  color: #F0A63A;
}

.preview-text {
  font-size: 28rpx;
  font-weight: 800;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(246, 247, 251, 0.94);
  backdrop-filter: blur(16rpx);
  box-sizing: border-box;
}

.generate-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: #182033;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 28rpx rgba(17, 24, 39, 0.18);
}

.generate-btn.disabled {
  opacity: 0.45;
  box-shadow: none;
}
