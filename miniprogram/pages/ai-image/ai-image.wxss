page {
  background: #F6F8FC;
  color: #182033;
}

.ai-page {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  background: linear-gradient(180deg, #EEF6FF 0%, #FFFFFF 34%, #F6F8FC 100%);
  position: relative;
  overflow: hidden;
}

.bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.28;
}

.c1 {
  width: 420rpx;
  height: 420rpx;
  background: #6FB1FC;
  top: -160rpx;
  left: -180rpx;
}

.c2 {
  width: 360rpx;
  height: 360rpx;
  background: #F0B96D;
  top: 220rpx;
  right: -160rpx;
}

.hero {
  padding: 44rpx 36rpx 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #111827 0%, #27435E 52%, #F0B96D 100%);
  color: #FFFFFF;
  overflow: hidden;
  position: relative;
  z-index: 1;
  box-shadow: 0 24rpx 58rpx rgba(17, 24, 39, 0.18);
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  bottom: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.hero-kicker {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.hero-title {
  margin-top: 24rpx;
  max-width: 560rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #FFFFFF;
}

.hero-desc {
  margin-top: 18rpx;
  max-width: 600rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.86);
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.hero-tags text {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.15);
  font-size: 22rpx;
  color: #FFFFFF;
}

.view-tabs,
.mode-tabs {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
  margin: 28rpx 0;
  padding: 8rpx;
  border-radius: 22rpx;
  background: rgba(232, 237, 246, 0.92);
  box-shadow: 0 10rpx 30rpx rgba(39, 67, 94, 0.08);
}

.view-tabs {
  margin-bottom: 22rpx;
}

.view-tab,
.mode-tab {
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A8A8A;
  font-size: 28rpx;
  font-weight: 700;
}

.view-tab.active,
.mode-tab.active {
  background: #FFFFFF;
  color: #182033;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.08);
}

.view-tab.active,
.mode-tab.active:first-child,
.mode-tab.active:last-child {
  color: #FFFFFF;
  background: linear-gradient(135deg, #27435E 0%, #4990E2 100%);
}

.panel,
.preview-panel,
.quota-panel,
.gallery-head,
.image-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(39, 67, 94, 0.06);
  box-shadow: 0 14rpx 42rpx rgba(39, 67, 94, 0.08);
}

.quota-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.quota-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #182033;
}

.quota-desc {
  margin-top: 8rpx;
  color: #8A8A8A;
  font-size: 24rpx;
}

.quota-button {
  flex-shrink: 0;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
}

.section-head,
.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #182033;
}

.section-tip {
  margin-top: 8rpx;
  color: #8A8A8A;
  font-size: 24rpx;
  line-height: 1.4;
}

.section-action {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 24rpx;
  font-weight: 700;
}

.prompt-input {
  width: 100%;
  min-height: 220rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #F5F7FA;
  color: #182033;
  font-size: 28rpx;
  line-height: 1.55;
}

.placeholder {
  color: #A0A7B3;
}

.input-meta {
  margin-top: 12rpx;
  text-align: right;
  color: #A0A7B3;
  font-size: 22rpx;
}

.upload-box {
  height: 360rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
  background: #F5F7FA;
  border: 2rpx dashed #C9D2E3;
  overflow: hidden;
}

.reference-image {
  width: 100%;
  height: 100%;
}

.upload-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #8A8A8A;
}

.upload-mark {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #27435E;
  font-size: 54rpx;
  font-weight: 300;
}

.upload-text {
  font-size: 26rpx;
}

.option-group {
  margin-top: 26rpx;
}

.option-label {
  margin-bottom: 16rpx;
  color: #8A8A8A;
  font-size: 25rpx;
  font-weight: 700;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-width: 112rpx;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #F5F7FA;
  color: #667085;
  text-align: center;
  font-size: 25rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.chip.selected {
  background: #27435E;
  color: #FFFFFF;
}

.preview-subtitle {
  margin-top: 8rpx;
  color: #8A8A8A;
  font-size: 23rpx;
  line-height: 1.4;
}

.model-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 22rpx;
  font-weight: 800;
}

.preview-canvas {
  height: 430rpx;
  margin-top: 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #E9F5FF 0%, #FFF7E8 100%);
  position: relative;
  overflow: hidden;
}

.result-image {
  width: 100%;
  height: 100%;
  background: #F5F7FA;
}

.result-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.result-action {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 24rpx;
  font-weight: 700;
}

.result-action.primary {
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(73, 144, 226, 0.18);
}

.preview-glow {
  position: absolute;
  inset: 34rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.28);
}

.preview-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #667085;
}

.preview-icon {
  font-size: 70rpx;
  color: #F0A63A;
}

.preview-text {
  font-size: 28rpx;
  font-weight: 800;
}

.bottom-bar {
  position: relative;
  z-index: 1;
  padding: 12rpx 0 0;
  box-sizing: border-box;
}

.generate-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #27435E 0%, #4990E2 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 30rpx rgba(39, 67, 94, 0.22);
}

.generate-btn.disabled {
  opacity: 0.45;
  box-shadow: none;
}

.gallery-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.gallery-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #182033;
}

.gallery-desc {
  margin-top: 8rpx;
  color: #8A8A8A;
  font-size: 24rpx;
}

.refresh-btn {
  flex-shrink: 0;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
}

.empty {
  position: relative;
  z-index: 1;
  min-height: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #8A8A8A;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #F0A63A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 12rpx 34rpx rgba(39, 67, 94, 0.1);
}

.empty-title {
  margin-top: 18rpx;
  color: #182033;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 10rpx;
  max-width: 500rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.image-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.image-card {
  padding: 0;
  overflow: hidden;
}

.image-wrap {
  width: 100%;
  height: 520rpx;
  background: linear-gradient(135deg, #E9F5FF 0%, #FFF7E8 100%);
}

.image-wrap.pending {
  display: flex;
  align-items: center;
  justify-content: center;
}

.work-image {
  width: 100%;
  height: 100%;
  background: #F5F7FA;
}

.skeleton-box,
.failed-box {
  width: 100%;
  height: 100%;
  padding: 46rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.skeleton-image,
.skeleton-line {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.46));
  background-size: 240% 100%;
  animation: skeletonMove 1.4s ease-in-out infinite;
}

.skeleton-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
}

.skeleton-line {
  width: 320rpx;
  height: 22rpx;
  border-radius: 999rpx;
  margin-bottom: 14rpx;
}

.skeleton-line.short {
  width: 220rpx;
}

@keyframes skeletonMove {
  0% {
    background-position: 120% 0;
  }

  100% {
    background-position: -120% 0;
  }
}

.failed-mark {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #FFF0F0;
  color: #D92D20;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 22rpx;
}

.status-title {
  color: #182033;
  font-size: 30rpx;
  font-weight: 800;
}

.status-desc {
  margin-top: 12rpx;
  color: #8A8A8A;
  font-size: 24rpx;
  line-height: 1.45;
}

.card-body {
  padding: 24rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-row text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 22rpx;
  font-weight: 700;
}

.prompt {
  margin-top: 16rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.image-meta,
.time-text {
  margin-top: 10rpx;
  color: #A0A7B3;
  font-size: 22rpx;
}

.image-meta {
  color: #667085;
  font-weight: 700;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.action {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 24rpx;
  font-weight: 800;
}

.action.primary {
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
}
