/* pages/trip-list/trip-list.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --success-color: #52C41A;
  --text-primary: #1a1a2e;
  --text-secondary: #666;
  --text-hint: #999;
  --bg-color: #f5f7fa;
  --border-color: #e8e8e8;
  background: var(--bg-color);
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 160rpx;
}

/* 列表区域 */
.list-container {
  padding: 24rpx;
}

.trip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 行程卡片 */
.trip-item {
  display: flex;
  flex-direction: column;
  padding: 28rpx 32rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.trip-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.trip-user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 36rpx;
  font-weight: 600;
}

.trip-user {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.trip-status {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.trip-status.has-car {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.trip-status.need-car {
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
}

.action-btn {
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: var(--primary-color);
  color: white;
}

.action-btn.outline {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.trip-meta-row {
  display: flex;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.trip-meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.trip-meta-label {
  color: var(--text-hint);
  margin-right: 12rpx;
}

.trip-remark {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.trip-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.trip-footer-stats {
  width: 100%;
  display: flex;
  justify-content: space-between;
}

.trip-stat {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1rpx solid var(--border-color);
}

.publish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 108rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.4);
}

.publish-icon {
  font-size: 40rpx;
  font-weight: 400;
}
