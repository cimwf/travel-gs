/* pages/trip-list/trip-list.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;
  --success-color: #52C41A;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: white;
  border-bottom: 1rpx solid var(--border-color);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  background: var(--bg-color);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-item.active {
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
}

.filter-arrow {
  font-size: 20rpx;
}

/* ========== 列表区域 ========== */
.list-container {
  flex: 1;
  height: 0;
}

.list-content {
  padding: 24rpx 32rpx 160rpx;
}

.trip-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ========== 行程卡片 ========== */
.trip-card {
  background: white;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.trip-header {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.trip-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.trip-img image {
  width: 100%;
  height: 100%;
}

.trip-emoji {
  font-size: 56rpx;
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.trip-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ========== 状态标签 ========== */
.trip-status {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.trip-status.recruiting {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.trip-status.almost-full {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.trip-status.full {
  background: rgba(140, 140, 160, 0.1);
  color: #8E8EA0;
}

.trip-status.stopped {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.trip-meta {
  font-size: 24rpx;
  color: var(--text-hint);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4rpx;
}

.meta-dot {
  color: var(--border-color);
  margin: 0 4rpx;
}

/* ========== 底部信息 ========== */
.trip-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.trip-footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.participants {
  display: flex;
  align-items: center;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  margin-left: -12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.participant-avatar:first-child {
  margin-left: 0;
}

.trip-need {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.publish-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.1), rgba(107, 163, 232, 0.05));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 24rpx 64rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}

/* ========== 悬浮发布按钮 ========== */
.fab {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.fab:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.fab-inner {
  width: 88rpx;
  height: 88rpx;
  border: 3rpx dashed var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-icon {
  font-size: 56rpx;
  color: var(--primary-color);
  font-weight: 300;
}

/* ========== 筛选弹窗 ========== */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.filter-panel {
  position: absolute;
  top: 200rpx;
  left: 32rpx;
  right: 32rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.filter-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.filter-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.filter-reset {
  font-size: 26rpx;
  color: var(--primary-color);
}

.filter-options {
  padding: 16rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.filter-option {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}

.filter-option:last-child {
  margin-bottom: 0;
}

.filter-option.selected {
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  font-weight: 500;
}

.filter-option:active {
  background: var(--bg-color);
}

/* ========== 自定义日期选择弹窗 ========== */
.date-picker-panel {
  position: absolute;
  top: 300rpx;
  left: 32rpx;
  right: 32rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.date-picker-content {
  padding: 32rpx;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.date-row:last-child {
  border-bottom: none;
}

.date-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.date-value {
  font-size: 28rpx;
  color: var(--primary-color);
  padding: 12rpx 24rpx;
  background: rgba(74, 144, 226, 0.1);
  border-radius: 12rpx;
}

.date-picker-footer {
  display: flex;
  border-top: 1rpx solid var(--border-color);
}

.date-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
}

.date-btn-cancel {
  color: var(--text-hint);
  border-right: 1rpx solid var(--border-color);
}

.date-btn-confirm {
  color: var(--primary-color);
  font-weight: 500;
}
