<!--pages/trip-list/trip-list.wxml-->
<view class="container">
  <!-- 列表区域 -->
  <view class="list-container">
    <view class="trip-list" wx:if="{{trips.length > 0}}">
      <view class="trip-item" wx:for="{{trips}}" wx:key="_id" bindtap="onTripTap" data-id="{{item._id}}">
        <!-- 顶部：头像+用户名+状态标签 | 操作按钮 -->
        <view class="trip-top">
          <view class="trip-user-info">
            <image class="user-avatar-img" src="{{item.creatorAvatar}}" wx:if="{{item.creatorAvatar}}" mode="aspectFill"></image>
            <view class="user-avatar" style="background: linear-gradient(135deg, #4A90E2, #6BA3E8);" wx:else>
              <text>{{item.creatorName ? item.creatorName[0] : '旅'}}</text>
            </view>
            <text class="trip-user">{{item.creatorName || '旅行者'}}</text>
            <!-- <view class="trip-status {{item.hasCar ? 'has-car' : 'need-car'}}">
              <text>{{item.hasCar ? '有车' : '需拼车'}}</text>
            </view> -->
          </view>
          <view class="action-btn {{item.hasCar ? 'primary' : 'outline'}}" catchtap="onActionTap" data-id="{{item._id}}" data-index="{{index}}" data-hascar="{{item.hasCar}}">
            {{item.hasCar ? '申请加入' : '邀请他'}}
          </view>
        </view>

        <!-- 信息栏：出发日期 | 出发地 | 人数 -->
        <view class="trip-meta-row">
          <view class="trip-meta-item">
            <text class="trip-meta-label">出发</text>
            <text>{{item.dateText || item.date}}</text>
          </view>
          <view class="trip-meta-item" wx:if="{{item.departure}}">
            <text>{{item.departure}}</text>
          </view>
          <view class="trip-meta-item">
            <text class="trip-meta-label">人数</text>
            <text>{{item.currentCount}}/{{item.totalCount}}人</text>
          </view>
        </view>

        <!-- 备注区域 -->
        <view class="trip-remark" wx:if="{{item.remark}}">{{item.remark}}</view>

        <!-- 底部：浏览量 + 发布时间 -->
        <view class="trip-footer">
          <view class="trip-footer-stats">
            <text class="trip-stat">👁 {{item.viewCount || 0}}次浏览</text>
            <text class="trip-stat">{{item.publishTime || '刚刚发布'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && trips.length === 0}}">
      <text class="empty-icon">🏕️</text>
      <text class="empty-text">暂无行程，快来发布第一个吧！</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore && trips.length > 0}}">
      <text>加载更多...</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer-bar">
    <view class="publish-btn" bindtap="onPublishTrip">
      <text class="publish-icon">+</text>
      <text>发布我的行程</text>
    </view>
  </view>
</view>
