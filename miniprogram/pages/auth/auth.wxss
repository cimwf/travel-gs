/* pages/auth/auth.wxss */
page {
  height: 100%;
  width: 100%;
  overflow: hidden;
}

.auth-page {
  height: 100%;
  width: 100%;
  position: relative;
  background: linear-gradient(180deg, #eef6ff 0%, #ffffff 100%);
}

/* 背景光斑 */
.bg {
  position: absolute;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.35;
}

.c1 {
  width: 300px;
  height: 300px;
  background: #4990e2;
  top: -80px;
  left: -100px;
}

.c2 {
  width: 250px;
  height: 250px;
  background: #7bb8ff;
  bottom: -100px;
  right: -80px;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  z-index: 100;
}

.back-icon {
  font-size: 24px;
  color: #666;
  font-weight: 300;
}

/* 内容区域 */
.auth-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 32px;
  text-align: center;
  box-sizing: border-box;
}

/* Logo */
.auth-logo {
  width: 72px;
  height: 72px;
  margin-bottom: 24px;
  border-radius: 20px;
  background: linear-gradient(135deg, #4990e2, #7bb8ff);
  color: #fff;
  font-size: 28px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12px 30px rgba(73, 144, 226, 0.25);
}

/* 标题 */
.auth-title {
  font-size: 22px;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 10px;
}

/* 描述 */
.auth-desc {
  font-size: 14px;
  color: #8a8a8a;
  margin-bottom: 40px;
  line-height: 1.6;
  white-space: pre-line;
}

/* 登录按钮 */
.phone-login-btn {
  width: 100%;
  height: 52px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #4990e2, #6fb1fc);
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  box-shadow: 0 10px 25px rgba(73, 144, 226, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18px;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 协议勾选 */
.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.checkbox-custom {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1px solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: white;
  flex-shrink: 0;
  margin-top: 2px;
}

.checkbox-custom.checked {
  background: #4990e2;
  border-color: #4990e2;
}

.agreement-text {
  font-size: 12px;
  color: #aaa;
  line-height: 1.6;
  text-align: left;
}

.agreement-text .link {
  color: #4990e2;
}

/* ===== 第二步：完善资料 ===== */

.profile-card {
  width: 100%;
  background: white;
  border-radius: 20px;
  padding: 40px 28px 32px;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
}

.profile-title {
  font-size: 18px;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 28px;
}

/* 头像选择器 */
.avatar-picker {
  width: 96px;
  height: 96px;
  margin: 0 auto 24px;
  padding: 0;
  background: none;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  line-height: 1;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 2px solid #e8e8e8;
}

.avatar-preview.has-avatar {
  border-color: #4990e2;
}

.avatar-placeholder {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #f0f4ff;
  border: 2px dashed #c0d0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 28px;
}

.avatar-tip {
  font-size: 12px;
  color: #999;
}

/* 昵称输入 */
.nickname-wrap {
  margin-bottom: 24px;
}

.nickname-input {
  width: 100%;
  height: 48px;
  border-radius: 12px;
  background: #f5f7fa;
  text-align: center;
  font-size: 16px;
  color: #1d1d1f;
  padding: 0 16px;
  box-sizing: border-box;
}

/* 完成按钮 */
.complete-btn {
  width: 100%;
  height: 48px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #4990e2, #6fb1fc);
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.complete-btn::after {
  border: none;
}

.complete-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 跳过链接 */
.skip-link {
  margin-top: 16px;
  font-size: 13px;
  color: #aaa;
  padding: 8px;
}
