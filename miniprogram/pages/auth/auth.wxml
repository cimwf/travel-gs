<!--pages/auth/auth.wxml-->
<view class="auth-page">

  <view class="auth-content">
    <!-- Logo -->
    <view class="auth-logo">🏔️</view>

    <!-- 品牌标题 -->
    <view class="auth-title">北京去哪玩</view>
    <view class="auth-subtitle">发现北京周边好去处</view>

    <!-- 登录表单卡片 -->
    <view class="auth-form-card">
      <!-- 手机号输入 -->
      <view class="form-item">
        <view class="form-label">手机号</view>
        <view class="phone-input-wrap">
          <input
            class="phone-input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{phoneNumber}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <!-- 验证码输入 -->
      <view class="form-item">
        <view class="form-label">验证码</view>
        <view class="code-input-wrap">
          <input
            class="code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            value="{{code}}"
            bindinput="onCodeInput"
          />
          <view
            class="code-btn {{countdown > 0 ? 'disabled' : ''}}"
            bindtap="onGetCode"
          >
            {{countdown > 0 ? countdown + '秒后重发' : '获取验证码'}}
          </view>
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn {{canLogin ? '' : 'disabled'}}">
        <button
          bindtap="onLogin"
          loading="{{loading}}"
        >
          登录
        </button>
      </view>
    </view>

    <!-- 暂不登录 -->
    <view class="skip-btn" bindtap="onSkip">
      暂不登录
    </view>

    <!-- 协议 -->
    <view class="auth-agreement">
      登录即表示同意
      <text class="link" bindtap="onOpenAgreement" data-type="user">《用户协议》</text>
      和
      <text class="link" bindtap="onOpenAgreement" data-type="privacy">《隐私政策》</text>
    </view>
  </view>
</view>
