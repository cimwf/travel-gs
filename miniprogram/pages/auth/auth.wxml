<!--pages/auth/auth.wxml-->
<view class="auth-page">
  <!-- 返回按钮 -->
  <view class="back-btn" style="top: {{statusBarHeight + 20}}px;" bindtap="onBack">
    <text class="back-icon">‹</text>
  </view>

  <view class="auth-content">
    <!-- Logo -->
    <view class="auth-logo">🏔️</view>

    <!-- 品牌标题 -->
    <view class="auth-title">北上周边行</view>
    <view class="auth-subtitle">发现北京周边好去处</view>

    <!-- 登录表单卡片 -->
    <view class="auth-form-card">
      <!-- 账号输入 -->
      <view class="form-item">
        <view class="form-label">账号</view>
        <view class="input-wrap">
          <text class="input-icon">👤</text>
          <input
            class="form-input"
            type="text"
            placeholder="请输入手机号"
            value="{{username}}"
            bindinput="onUsernameInput"
          />
        </view>
      </view>

      <!-- 密码输入 -->
      <view class="form-item">
        <view class="form-label">密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input
            class="form-input"
            password="{{!showPassword}}"
            placeholder="请输入密码"
            value="{{password}}"
            bindinput="onPasswordInput"
          />
          <view class="eye-icon" bindtap="onTogglePassword">
            <text>{{showPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
      </view>

      <!-- 忘记密码 -->
      <view class="forget-password" bindtap="onForgetPassword">
        <text>忘记密码？</text>
      </view>

      <!-- 登录按钮 -->
      <view class="login-btn">
        <button
          class="{{canLogin ? '' : 'disabled'}}"
          bindtap="onLogin"
          loading="{{loading}}"
        >
          登录
        </button>
      </view>
    </view>

    <!-- 注册引导 -->
    <view class="register-guide">
      <text class="guide-text">还没有账号？</text>
      <text class="guide-link" bindtap="onGoRegister">立即注册</text>
    </view>

    <!-- 协议 -->
    <view class="auth-agreement">
      登录即表示同意
      <text class="link" bindtap="onOpenAgreement" data-type="user">《用户协议》</text>
      和
      <text class="link" bindtap="onOpenAgreement" data-type="privacy">《隐私政策》</text>
    </view>
  </view>
</view>
