<!--
  首页 (index)
  ================================
  设计要点：
  1. 搜索框 - 点击跳转搜索页
  2. Banner轮播图 - 自动轮播展示热门活动/推荐地点
  3. 地点列表 - 纵向滚动卡片列表
  4. 无需登录即可访问
  5. 底部Tab Bar

  参考：E:\beijing-travel\docs\design-spec.html
-->

<view class="container">
  <!-- 搜索栏 -->
  <!-- <view class="search-section">
    <view class="search-bar" bindtap="onSearchTap">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索地点、目的地</text>
    </view>
  </view> -->

  <!-- Banner轮播图 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="4000" duration="500" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.bgColor}};" data-id="{{item.id}}" data-type="{{item.type}}" bindtap="onBannerTap">
          <text class="banner-title">{{item.icon}} {{item.title}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 地点列表 -->
  <scroll-view class="place-list" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onPullDownRefresh">
    <block wx:if="{{!loading && places.length > 0}}">
      <view
        class="place-card"
        wx:for="{{places}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="onPlaceTap"
      >
        <image class="place-image" src="{{item.coverImage}}" mode="aspectFill" wx:if="{{item.coverImage}}"></image>
        <view class="place-image" style="background: {{item.bgColor || 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'}};" wx:else>
          <text class="place-icon">{{item.icon || '🏔️'}}</text>
        </view>
        <view class="place-info">
          <view class="place-name">{{item.name}}</view>
          <view class="place-desc">{{item.intro || '暂无简介'}}</view>
          <view class="place-meta">
            <text class="meta-item">📍 {{item.distance}}km</text>
            <text class="meta-item">⚡ {{item.difficulty}}</text>
            <text class="meta-item">⭐ {{item.rating || '4.5'}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && places.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无地点数据</text>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>
  </scroll-view>
</view>
