/* pages/index/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F7FA;
}

/* 顶部导航栏 - 全屏宽度 */
.nav-header {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 48rpx 32rpx 36rpx;
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.nav-title {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 12rpx;
}

.nav-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 搜索栏 - 全屏宽度 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: white;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  box-sizing: border-box;
  margin: 0;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 48rpx;
  padding: 24rpx 32rpx;
}

.search-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}

.search-input input {
  flex: 1;
  font-size: 30rpx;
  width: 100%;
}

.publish-btn {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24rpx;
  color: white;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.35);
}

/* 分类标签 - 全屏宽度 */
.category-scroll {
  background: white;
  white-space: nowrap;
  border-bottom: 1rpx solid #EEEEEE;
  width: 100%;
}

.category-list {
  display: inline-flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 18rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  background: #F5F7FA;
  transition: all 0.2s ease;
}

.category-item.active {
  background: #4A90E2;
  color: white;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

/* 地点列表 - 两侧留出边距 */
.place-list {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
}

.place-card {
  display: flex;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  width: 100%;
  box-sizing: border-box;
}

.place-image {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.place-info {
  flex: 1;
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.place-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.place-meta {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.place-meta .distance {
  margin-right: 28rpx;
}

.place-meta .difficulty {
  padding: 6rpx 20rpx;
  background: rgba(126, 211, 33, 0.15);
  color: #7ED321;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.place-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.place-tags .tag {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.place-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.want-count {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #4A90E2;
  font-weight: 500;
}

.want-count text {
  margin-right: 8rpx;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}
