/* pages/index/index.wxss */

/* ========================================
   北京去哪玩 - 首页设计规格
   设计稿：docs/design-spec.html
   设计稿宽度：375px (1px = 2rpx)
   ======================================== */

page {
  /* 主色 */
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;

  /* 文字颜色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  /* 背景与边框 */
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;

  /* 功能色 */
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;

  /* 禁用横向滚动 */
  overflow-x: hidden;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  /* background: var(--bg-color); */
  overflow-x: hidden;
  box-sizing: border-box;

}

/* ========================================
   搜索框区域
   padding: 16px, 背景: white
   搜索框: 圆角24px, 背景: #F5F7FA, padding: 12px 16px
   ======================================== */
.search-section {
  width: 100%;
  padding: 32rpx 0;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 48rpx;
}

.search-icon {
  font-size: 32rpx;
}

.search-placeholder {
  font-size: 30rpx;
  color: var(--text-hint);
}

/* ========================================
   Banner轮播图
   高度: 120px, 圆角: 16px
   背景: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
   指示点: 6px, 间距6px
   ======================================== */
.banner-section {
  width: 100%;
  margin-top: 32rpx;
  padding: 0 32rpx 32rpx;
}

.banner-swiper {
  height: 240rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========================================
   地点列表
   卡片: 圆角16px, 间距12px
   左图: 100px × 100px
   右侧信息: padding 12px
   标题: 16px font-weight:600
   描述: 13px
   信息: 12px
   ======================================== */
.place-list {
  flex: 1;
  height: 0;
  padding: 0 32rpx 32rpx;
  overflow-y: auto;
}

.place-card {
  display: flex;
  background: var(--card-bg);
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.place-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  overflow: hidden;
}

.place-icon {
  font-size: 80rpx;
}

.place-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.place-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.place-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.place-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.meta-item {
  display: flex;
  align-items: center;
}

/* ========================================
   加载状态
   ======================================== */
.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   空状态
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========================================
   底部安全区
   Tab Bar: 导航49px + 安全区34px = 83px
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 166rpx);
}
