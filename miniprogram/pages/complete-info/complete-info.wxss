/* pages/complete-info/complete-info.wxss */
page {
  height: 100%;
}

.complete-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #F5F7FA;
}

/* 状态栏 */
.status-bar {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  color: white;
  font-size: 14px;
  font-weight: 500;
  background: #4A90E2;
}

.status-bar .time {
  font-weight: 600;
}

.status-bar .icons {
  display: flex;
  gap: 5px;
}

/* 头部 */
.complete-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20px 20px 40px;
  color: white;
}

.back {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 16px;
  opacity: 0.9;
  margin-bottom: 20px;
}

.header-title {
  font-size: 24px;
  font-weight: 600;
  text-align: center;
}

/* 表单 */
.complete-form {
  flex: 1;
  margin: -30px 16px 0;
  background: white;
  border-radius: 20px;
  padding: 24px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

/* 头像 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24px;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrapper {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 8px;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.4);
}

.avatar-wrapper image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  font-size: 40px;
  color: white;
}

.avatar-overlay {
  font-size: 11px;
  color: #999;
  text-align: center;
}

.avatar-tip {
  font-size: 12px;
  color: #999;
}

/* 表单项 */
.form-group {
  margin-bottom: 20px;
}

.form-label {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  font-weight: 500;
}

.required {
  color: #f5576c;
}

.form-input {
  width: 100%;
  padding: 14px 16px;
  background: #F5F7FA;
  border: 1px solid transparent;
  border-radius: 12px;
  font-size: 15px;
  color: #333;
  transition: all 0.2s;
}

.form-input:focus {
  background: white;
  border-color: #4A90E2;
  outline: none;
}

.form-input::placeholder {
  color: #999;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 12px;
}

.gender-option {
  flex: 1;
  padding: 12px;
  background: #F5F7FA;
  border-radius: 12px;
  text-align: center;
  font-size: 14px;
  color: #666;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.gender-option.active {
  background: rgba(74, 144, 226, 0.1);
  border-color: #4A90E2;
  color: #4A90E2;
  font-weight: 500;
}

/* 协议 */
.agreement-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-bottom: 24px;
  padding: 12px;
  background: #F5F7FA;
  border-radius: 8px;
}

.agreement-checkbox {
  transform: scale(0.8);
  margin-top: 2px;
}

.agreement-text {
  font-size: 12px;
  color: #666;
  line-height: 1.6;
}

.agreement-text .link {
  color: #4A90E2;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 50px;
  font-size: 17px;
  font-weight: 600;
  color: white;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
}