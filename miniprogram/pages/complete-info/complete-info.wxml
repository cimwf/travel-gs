<!--pages/complete-info/complete-info.wxml-->
<view class="complete-page">
  <!-- 状态栏 -->
  <view class="status-bar">
    <text class="time">{{time}}</text>
    <view class="icons">
      <text>📶</text>
      <text>🔋</text>
    </view>
  </view>
  
  <!-- 头部 -->
  <view class="complete-header">
    <view class="back" bindtap="onBack">
      <text>←</text>
      <text>返回</text>
    </view>
    <view class="header-title">完善信息</view>
  </view>
  
  <!-- 表单 -->
  <view class="complete-form">
    <!-- 头像 -->
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-wrapper">
          <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill"></image>
          <text wx:else class="avatar-placeholder">👤</text>
        </view>
        <view class="avatar-overlay">点击更换</view>
      </button>
      <view class="avatar-tip">点击可使用微信头像或上传图片</view>
    </view>
    
    <!-- 昵称 -->
    <view class="form-group">
      <view class="form-label">
        昵称 <text class="required">*</text>
      </view>
      <input 
        class="form-input" 
        type="nickname" 
        placeholder="请输入昵称" 
        value="{{nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
    </view>
    
    <!-- 性别 -->
    <view class="form-group">
      <view class="form-label">性别</view>
      <view class="gender-group">
        <view 
          class="gender-option {{gender === 1 ? 'active' : ''}}" 
          data-gender="1" 
          bindtap="onGenderChange"
        >男</view>
        <view 
          class="gender-option {{gender === 2 ? 'active' : ''}}" 
          data-gender="2" 
          bindtap="onGenderChange"
        >女</view>
        <view 
          class="gender-option {{gender === 0 ? 'active' : ''}}" 
          data-gender="0" 
          bindtap="onGenderChange"
        >保密</view>
      </view>
    </view>
    
    <!-- 协议 -->
    <view class="agreement-item">
      <checkbox 
        class="agreement-checkbox" 
        checked="{{agreed}}" 
        bindtap="onAgreeChange" 
        color="#4A90E2"
      />
      <view class="agreement-text">
        我已阅读并同意
        <text class="link" bindtap="onOpenAgreement" data-type="user">《用户协议》</text>
        和
        <text class="link" bindtap="onOpenAgreement" data-type="privacy">《隐私政策》</text>
      </view>
    </view>
    
    <!-- 提交按钮 -->
    <button 
      class="submit-btn" 
      bindtap="onSubmit" 
      loading="{{loading}}"
      disabled="{{!canSubmit}}"
    >完成注册</button>
  </view>
</view>