<view class="container">
  <view class="form-card">
    <!-- 地点名称 -->
    <view class="form-item">
      <view class="form-label">地点名称</view>
      <view class="input-wrap">
        <input
          class="form-input"
          placeholder="请输入景点名称"
          value="{{placeName}}"
          bindinput="onPlaceNameInput"
        />
      </view>
    </view>

    <!-- 所在地方 -->
    <view class="form-item">
      <view class="form-label">所在地方</view>
      <view class="input-wrap">
        <input
          class="form-input"
          placeholder="例如：北京市延庆区"
          value="{{location}}"
          bindinput="onLocationInput"
        />
      </view>
    </view>

    <!-- 景点头像 -->
    <view class="form-item">
      <view class="form-label">景点头像</view>
      <view class="upload-area" bindtap="onChooseImage">
        <image wx:if="{{coverImage}}" class="preview-image" src="{{coverImage}}" mode="aspectFill"></image>
        <view wx:else class="upload-placeholder">
          <text class="upload-icon">+</text>
          <text class="upload-text">点击上传图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 上传按钮 -->
  <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="onSubmit">
    <button loading="{{loading}}">上传景点</button>
  </view>
</view>
