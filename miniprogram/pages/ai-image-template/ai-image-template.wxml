<view class="template-page">
  <view class="hero">
    <view class="hero-kicker">模板库</view>
    <view class="hero-title">一键挑模板，直接出图</view>
    <view class="hero-desc">先选一个方向，再让 AI 把细节补齐，测试用户会更容易立刻生成第一张图。</view>
  </view>

  <view class="mode-tabs">
    <view class="mode-tab {{activeMode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="onSwitchMode">文生图</view>
    <view class="mode-tab {{activeMode === 'image' ? 'active' : ''}}" data-mode="image" bindtap="onSwitchMode">图生图</view>
  </view>

  <scroll-view class="scene-filter" scroll-x="true" show-scrollbar="false" wx:if="{{scenes.length > 1}}">
    <view class="scene-track">
      <view
        class="scene-chip {{activeScene === item.value ? 'active' : ''}}"
        wx:for="{{scenes}}"
        wx:key="value"
        data-scene="{{item.value}}"
        bindtap="onSwitchScene"
      >
        <text>{{item.label}}</text>
        <text class="scene-count">{{item.count}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="template-list">
    <view class="empty-state" wx:if="{{!templates.length && !loading}}">
      <view class="empty-title">还没有模板</view>
      <view class="empty-desc">请到后台新增模板，上传后会显示在这里。</view>
    </view>
    <view class="template-card" wx:for="{{templates}}" wx:key="_id" data-template="{{item}}" bindtap="onSelectTemplate">
      <image class="template-cover" wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view class="template-card-top">
        <text class="template-badge">{{item.badge}}</text>
        <text class="template-ratio">{{item.ratio}}</text>
      </view>
      <view class="template-name">{{item.title}}</view>
      <view class="template-desc">{{item.desc}}</view>
      <view class="template-meta">
        <text class="template-scene">{{item.scene || '未分类'}}</text>
      </view>
      <view class="template-prompt">{{item.prompt}}</view>
      <view class="template-footer">
        <text class="template-style">{{item.style || '无风格'}}</text>
        <view class="vote-row">
          <view class="vote-btn {{item.userVote === 'like' ? 'active' : ''}}" data-id="{{item._id || item.id}}" data-vote="like" catchtap="onVoteTemplate">赞 {{item.likeCount || 0}}</view>
          <view class="vote-btn {{item.userVote === 'dislike' ? 'active' : ''}}" data-id="{{item._id || item.id}}" data-vote="dislike" catchtap="onVoteTemplate">踩 {{item.dislikeCount || 0}}</view>
          <view class="template-use">使用这个</view>
        </view>
      </view>
    </view>
  </view>
</view>
