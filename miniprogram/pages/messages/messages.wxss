/* pages/messages/messages.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
}

/* 未登录状态 */
.not-login {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 64rpx;
}

.not-login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.not-login-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
}

/* 分区 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  padding: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  background: white;
}

/* 通知列表 */
.notice-list {
  background: white;
}

.notice-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.notice-content {
  flex: 1;
}

.notice-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.notice-time {
  font-size: 24rpx;
  color: #999;
}

/* 会话列表 */
.conversation-list {
  background: white;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.conversation-item:last-child {
  border-bottom: none;
}

.conversation-item:active {
  background: #F9F9F9;
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.unread-dot {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background: #FF4D4F;
  border-radius: 18rpx;
  font-size: 20rpx;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.conversation-content {
  flex: 1;
  overflow: hidden;
}

.conversation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.conversation-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.conversation-time {
  font-size: 24rpx;
  color: #999;
}

.conversation-preview {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  background: white;
}
