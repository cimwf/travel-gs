/* pages/messages/messages.wxss */

/* ========================================
   北京去哪玩 - 消息页面设计规格
   设计稿：docs/design-spec.html
   ======================================== */

page {
  /* 主色 */
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;

  /* 文字颜色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  /* 背景与边框 */
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;

  /* 功能色 */
  --danger-color: #FF4D4F;
}

.container {
  min-height: 100vh;
  background: var(--card-bg);
}

/* ========================================
   未登录状态
   居中布局，图标+标题+描述+按钮
   ======================================== */
.not-login {
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: var(--card-bg);
}

.not-login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 64rpx;
  text-align: center;
}

.not-login-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 40rpx;
}

.not-login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.not-login-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 96rpx;
  background: var(--primary-color);
  border-radius: 48rpx;
}

.login-btn:active {
  background: var(--primary-dark);
}

.login-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========================================
   已登录状态 - 顶部导航
   背景: white, 居中标题
   ======================================== */
.nav-header {
  background: var(--card-bg);
  padding: 32rpx 16rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ========================================
   消息列表
   背景: white
   ======================================== */
.message-list {
  background: var(--card-bg);
  flex: 1;
}

/* 消息卡片 */
.message-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border-color);
}

.message-card:active {
  background: var(--bg-color);
}

.message-card:last-child {
  border-bottom: none;
}

/* 头像 */
.message-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  position: relative;
}

.message-avatar text {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 消息内容 */
.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.message-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.message-time {
  font-size: 24rpx;
  color: var(--text-hint);
}

.message-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 未读badge */
.message-badge {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: var(--danger-color);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  right: 0;
  top: 0;
}

.message-badge text {
  font-size: 24rpx;
  color: #FFFFFF;
}

/* ========================================
   加载状态
   ======================================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   底部安全区
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}
