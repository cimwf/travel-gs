/* pages/messages/messages.wxss */

/* ========================================
   🎨 设计系统 - Design Token System
   ======================================== */
page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #3A7BC8;
  --primary-bg: rgba(74, 144, 226, 0.08);
  
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --text-white: #FFFFFF;
  
  --border-color: #E8E8F0;
  --divider-color: #F0F0F5;
  
  --success-color: #52C41A;
  --success-bg: rgba(82, 196, 26, 0.1);
  --warning-color: #FAAD14;
  --warning-bg: rgba(250, 173, 20, 0.1);
  --danger-color: #FF4D4F;
  --danger-bg: rgba(255, 77, 79, 0.1);
  
  /* 阴影系统 */
  --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
  
  /* 圆角系统 */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  /* 动画 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.4s ease;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* ========================================
   未登录状态
   ======================================== */
.not-login {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  position: relative;
  overflow: hidden;
}

.not-login::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 600rpx;
  height: 600rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  animation: float 6s ease-in-out infinite;
}

.not-login::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  animation: float 8s ease-in-out infinite reverse;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-30rpx) rotate(5deg); }
}

.not-login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx;
  position: relative;
  z-index: 1;
}

.not-login-icon {
  font-size: 180rpx;
  margin-bottom: 40rpx;
  filter: drop-shadow(0 12rpx 32rpx rgba(0, 0, 0, 0.2));
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.not-login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.not-login-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 56rpx;
}

.login-btn {
  padding: 32rpx 96rpx;
  background: white;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-lg);
  transition: all var(--transition-normal);
}

.login-btn:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.login-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-color);
  letter-spacing: 2rpx;
}

/* ========================================
   顶部导航
   ======================================== */
.nav-header {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
}

.nav-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.nav-title {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  letter-spacing: 1rpx;
}

.nav-actions {
  display: flex;
  gap: 16rpx;
}

.nav-action-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  transition: all var(--transition-fast);
}

.nav-action-btn:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.92);
}

.action-icon {
  font-size: 32rpx;
}

/* 标签切换 */
.nav-tabs {
  display: flex;
  padding: 0 24rpx 24rpx;
  gap: 8rpx;
}

.nav-tab {
  position: relative;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all var(--transition-normal);
}

.nav-tab.active {
  background: white;
  color: var(--primary-color);
  font-weight: 600;
}

.nav-tab:active:not(.active) {
  background: rgba(255, 255, 255, 0.15);
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: var(--danger-color);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-tab.active .tab-badge {
  background: var(--primary-color);
}

/* ========================================
   加载状态
   ======================================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   内容滚动区域
   ======================================== */
.content-scroll {
  height: calc(100vh - env(safe-area-inset-top) - 180rpx);
}

/* ========================================
   快捷入口
   ======================================== */
.quick-actions {
  display: flex;
  padding: 24rpx;
  gap: 16rpx;
  background: white;
  margin: 24rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.quick-action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
  transition: all var(--transition-fast);
}

.quick-action-item:active {
  transform: scale(0.95);
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.quick-icon.trip {
  background: linear-gradient(135deg, #56AB2F, #A8E6CF);
}

.quick-icon.apply {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.quick-icon.system {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
}

.quick-icon.group {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.quick-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.quick-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: var(--danger-color);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========================================
   分区样式
   ======================================== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-icon {
  font-size: 32rpx;
}

.section-action {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 8rpx 16rpx;
}

.section-action:active {
  opacity: 0.7;
}

/* ========================================
   通知列表
   ======================================== */
.notice-list {
  background: white;
  border-radius: var(--radius-lg);
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--divider-color);
  position: relative;
  transition: all var(--transition-fast);
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-item:active {
  background: var(--bg-color);
}

.notice-item.unread {
  background: var(--primary-bg);
}

.notice-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-icon-wrap.apply {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.notice-icon-wrap.trip {
  background: linear-gradient(135deg, #56AB2F, #A8E6CF);
}

.notice-icon-wrap.system {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
}

.notice-icon {
  font-size: 40rpx;
}

.notice-content {
  flex: 1;
  min-width: 0;
}

.notice-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.notice-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.notice-tag {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.notice-tag.apply {
  background: var(--primary-bg);
  color: var(--primary-color);
}

.notice-time {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 操作按钮 */
.notice-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.notice-btn {
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  transition: all var(--transition-fast);
}

.notice-btn.reject {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.notice-btn.reject:active {
  background: var(--divider-color);
}

.notice-btn.accept {
  background: var(--primary-color);
  color: white;
}

.notice-btn.accept:active {
  background: var(--primary-dark);
}

.unread-dot {
  position: absolute;
  top: 32rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--danger-color);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.8; }
}

/* ========================================
   会话列表
   ======================================== */
.conversation-list {
  background: white;
  border-radius: var(--radius-lg);
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--divider-color);
  transition: all var(--transition-fast);
}

.conversation-item:last-child {
  border-bottom: none;
}

.conversation-item:active {
  background: var(--bg-color);
}

.avatar-wrap {
  position: relative;
  margin-right: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
}

.avatar text {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
}

.online-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  background: var(--success-color);
  border-radius: 50%;
  border: 4rpx solid white;
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  background: var(--danger-color);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid white;
}

.conversation-content {
  flex: 1;
  min-width: 0;
}

.conversation-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.conversation-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.conversation-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.group-icon {
  font-size: 24rpx;
}

.conversation-time {
  font-size: 24rpx;
  color: var(--text-hint);
}

.conversation-preview {
  font-size: 26rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 420rpx;
}

.preview-type {
  color: var(--primary-color);
}

/* ========================================
   空状态卡片
   ======================================== */
.empty-card {
  background: white;
  border-radius: var(--radius-lg);
  margin: 0 24rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-xs);
}

.empty-illustration {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  filter: grayscale(20%);
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 24rpx;
}

.empty-action {
  padding: 20rpx 48rpx;
  background: var(--primary-color);
  color: white;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
}

.empty-action:active {
  background: var(--primary-dark);
  transform: scale(0.96);
}

/* ========================================
   搜索弹窗
   ======================================== */
.search-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.search-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  padding: calc(env(safe-area-inset-top) + 20rpx) 24rpx 32rpx;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from { transform: translateY(-100%); }
  to { transform: translateY(0); }
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: var(--radius-full);
  padding: 20rpx 28rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 8rpx;
}

.search-results {
  margin-top: 24rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.search-result-item {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.search-empty {
  text-align: center;
  padding: 48rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}

/* ========================================
   底部安全区
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}
