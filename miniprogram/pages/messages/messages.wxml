<!--pages/messages/messages.wxml-->
<view class="container">
  <!-- 未登录状态 -->
  <view class="not-login" wx:if="{{!isLoggedIn}}">
    <view class="not-login-icon">💬</view>
    <view class="not-login-text">登录后查看消息</view>
    <view class="login-btn" bindtap="onTapLogin">立即登录</view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 通知列表 -->
    <view class="section">
      <view class="section-title">通知</view>
      <view class="notice-list" wx:if="{{notifications.length > 0}}">
        <view class="notice-item" wx:for="{{notifications}}" wx:key="_id">
          <view class="notice-icon">{{item.type === 'apply' ? '📬' : '🔔'}}</view>
          <view class="notice-content">
            <view class="notice-text">{{item.content}}</view>
            <view class="notice-time">{{item.time}}</view>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>
        <text>暂无通知</text>
      </view>
    </view>

    <!-- 会话列表 -->
    <view class="section">
      <view class="section-title">会话</view>
      <view class="conversation-list" wx:if="{{conversations.length > 0}}">
        <view class="conversation-item" wx:for="{{conversations}}" wx:key="_id" bindtap="onTapConversation" data-id="{{item._id}}">
          <view class="avatar-wrap">
            <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
            <view class="unread-dot" wx:if="{{item.unreadCount > 0}}">{{item.unreadCount}}</view>
          </view>
          <view class="conversation-content">
            <view class="conversation-header">
              <view class="conversation-name">{{item.name}}</view>
              <view class="conversation-time">{{item.lastTime}}</view>
            </view>
            <view class="conversation-preview">{{item.lastMessage}}</view>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>
        <text>暂无会话</text>
      </view>
    </view>
  </block>
</view>
