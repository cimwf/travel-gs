<!--
  消息页面 (messages)
  ================================
  设计稿：docs/design-spec.html

  未登录状态：居中登录引导
  已登录状态：消息列表（行程群聊、私聊、系统通知）
-->

<view class="container">
  <!-- 未登录状态 -->
  <view class="not-login" wx:if="{{!isLoggedIn}}">
    <view class="not-login-content">
      <view class="not-login-icon">💬</view>
      <view class="not-login-title">登录后查看消息</view>
      <view class="not-login-desc">登录后可以查看行程群聊、私聊消息和系统通知</view>
      <view class="login-btn" bindtap="onTapLogin">
        <text>立即登录</text>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 消息列表 -->
    <scroll-view class="message-list" scroll-y wx:else>
      <block wx:if="{{messages.length > 0}}">
        <view
          class="message-card"
          wx:for="{{messages}}"
          wx:key="_id"
          bindtap="onTapMessage"
          data-id="{{item._id}}"
          data-type="{{item.type}}"
        >
          <view class="message-avatar" style="background: {{item.avatarBg}};">
            <text>{{item.avatarText || item.name[0]}}</text>
            <view class="message-badge" wx:if="{{item.unreadCount > 0}}">
              <text>{{item.unreadCount}}</text>
            </view>
          </view>
          <view class="message-content">
            <view class="message-header">
              <view class="message-name">{{item.name}}</view>
              <view class="message-time">{{item.time}}</view>
            </view>
            <view class="message-text">{{item.lastMessage}}</view>
          </view>
          <!-- <view class="message-badge" wx:if="{{item.unreadCount > 0}}">
            <text>{{item.unreadCount}}</text>
          </view> -->
        </view>
      </block>

      <!-- 空状态 -->
      <view class="not-login-content" wx:else>
        <view class="not-login-icon">📭</view>
        <view class="not-login-title">暂无消息</view>
        <view class="not-login-desc">参与行程后会有消息通知哦</view>
      </view>

      <!-- 底部安全区 -->
      <view class="safe-bottom"></view>
    </scroll-view>
  </block>
</view>
