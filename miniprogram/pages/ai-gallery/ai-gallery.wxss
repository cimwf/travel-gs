page {
  background: #F6F8FC;
  color: #182033;
}

.gallery-page {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  background: linear-gradient(180deg, #EEF6FF 0%, #FFFFFF 34%, #F6F8FC 100%);
  position: relative;
  overflow: hidden;
}

.bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.28;
}

.c1 {
  width: 420rpx;
  height: 420rpx;
  background: #6FB1FC;
  top: -160rpx;
  left: -180rpx;
}

.c2 {
  width: 360rpx;
  height: 360rpx;
  background: #F0B96D;
  top: 220rpx;
  right: -160rpx;
}

.summary-card,
.image-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(39, 67, 94, 0.06);
  box-shadow: 0 14rpx 42rpx rgba(39, 67, 94, 0.08);
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #182033;
}

.summary-desc {
  margin-top: 8rpx;
  color: #8A8A8A;
  font-size: 24rpx;
}

.refresh-btn {
  flex-shrink: 0;
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
}

.empty {
  position: relative;
  z-index: 1;
  min-height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #8A8A8A;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #F0A63A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 12rpx 34rpx rgba(39, 67, 94, 0.1);
}

.empty-title {
  margin-top: 18rpx;
  color: #182033;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 10rpx;
  max-width: 500rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.image-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.image-card {
  overflow: hidden;
}

.image-wrap {
  width: 100%;
  height: 520rpx;
  background: linear-gradient(135deg, #E9F5FF 0%, #FFF7E8 100%);
}

.image-wrap.pending {
  display: flex;
  align-items: center;
  justify-content: center;
}

.work-image {
  width: 100%;
  height: 100%;
  background: #F5F7FA;
}

.skeleton-box,
.failed-box {
  width: 100%;
  height: 100%;
  padding: 46rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.skeleton-image,
.skeleton-line {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.46));
  background-size: 240% 100%;
  animation: skeletonMove 1.4s ease-in-out infinite;
}

.skeleton-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
}

.skeleton-line {
  width: 320rpx;
  height: 22rpx;
  border-radius: 999rpx;
  margin-bottom: 14rpx;
}

.skeleton-line.short {
  width: 220rpx;
}

@keyframes skeletonMove {
  0% {
    background-position: 120% 0;
  }

  100% {
    background-position: -120% 0;
  }
}

.failed-mark {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #FFF0F0;
  color: #D92D20;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 22rpx;
}

.status-title {
  color: #182033;
  font-size: 30rpx;
  font-weight: 800;
}

.status-desc {
  margin-top: 12rpx;
  color: #8A8A8A;
  font-size: 24rpx;
  line-height: 1.45;
}

.card-body {
  padding: 24rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-row text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 22rpx;
  font-weight: 700;
}

.prompt {
  margin-top: 16rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}

.image-meta,
.time-text {
  margin-top: 10rpx;
  color: #A0A7B3;
  font-size: 22rpx;
}

.image-meta {
  color: #667085;
  font-weight: 700;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.action {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #EEF6FF;
  color: #27435E;
  font-size: 24rpx;
  font-weight: 800;
}

.action.danger {
  background: #FFF0F0;
  color: #D92D20;
}

.action.primary {
  background: linear-gradient(135deg, #27435E, #4990E2);
  color: #FFFFFF;
}
