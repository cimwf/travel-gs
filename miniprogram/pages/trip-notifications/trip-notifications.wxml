<!--
  行程通知页面 (trip-notifications)
  ================================
  设计稿：docs/design-spec.html

  未登录状态：居中登录引导
  已登录状态：行程消息列表（申请通知合并展示）
-->
<view class="container">
  <!-- 未登录状态 -->
  <view class="not-login" wx:if="{{!isLoggedIn}}">
    <view class="not-login-content">
      <view class="not-login-icon">💬</view>
      <view class="not-login-title">登录后查看消息</view>
      <view class="not-login-desc">登录后可以查看行程通知、申请和邀请消息</view>
      <view class="login-btn" bindtap="onTapLogin">
        <text>立即登录</text>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 行程通知列表 -->
    <scroll-view class="notification-list" scroll-y wx:else>
      <view class="list-content">
        <block wx:if="{{notifications.length > 0}}">
          <view class="notification-card" wx:for="{{notifications}}" wx:key="_id">

            <!-- 我收到的申请：别人申请加入我的行程 -->
            <block wx:if="{{item.type === 'received'}}">
              <!-- 未处理 -->
              <block wx:if="{{!item.isHandled}}">
                <view class="card-header">
                  <view class="user-avatar" style="background: {{item.avatarBg}}">
                    <image wx:if="{{item.fromUserAvatar}}" class="avatar-image" src="{{item.fromUserAvatar}}" mode="aspectFill"></image>
                    <text wx:else>{{item.userName[0]}}</text>
                  </view>
                  <view class="header-info">
                    <view class="header-title">{{item.headerTitle}}</view>
                    <view class="header-meta">{{item.headerMeta}} · {{item.timeAgo}}</view>
                  </view>
                </view>

                <view class="card-detail">
                  <view class="detail-row" wx:if="{{item.contactValue}}">
                    <text class="detail-label">{{item.contactType === 'phone' ? '手机号：' : '微信号：'}}</text>
                    <text class="detail-value">{{item.contactValue}}</text>
                  </view>
                  <view class="detail-row" wx:if="{{item.introduction}}">
                    <text class="detail-label">备注：</text>
                    <text class="detail-value">{{item.introduction}}</text>
                  </view>
                </view>

                <view class="card-actions">
                  <view class="action-btn reject" catchtap="onRejectApply" data-id="{{item._id}}">拒绝</view>
                  <view class="action-btn agree" catchtap="onAgreeApply" data-id="{{item._id}}">同意</view>
                </view>
              </block>

              <!-- 已处理 -->
              <view class="card-handled" wx:else>
                <view class="user-avatar" style="background: {{item.avatarBg}}">
                  <image wx:if="{{item.fromUserAvatar}}" class="avatar-image" src="{{item.fromUserAvatar}}" mode="aspectFill"></image>
                  <text wx:else>{{item.userName[0]}}</text>
                </view>
                <view class="header-info">
                  <view class="header-title">{{item.headerTitle}}</view>
                  <view class="header-meta">{{item.headerMeta}} · {{item.timeAgo}}</view>
                </view>
                <text class="status-text {{item.status}}">{{item.statusText}}</text>
              </view>
            </block>

            <!-- 我发出的申请：我申请加入别人的行程 -->
            <block wx:if="{{item.type === 'sent'}}">
              <view class="sent-header">
                <view class="trip-icon" style="background: {{item.placeBg}}">
                  <text class="trip-emoji">{{item.placeEmoji}}</text>
                </view>
                <view class="sent-info">
                  <view class="sent-title">{{item.placeName}}</view>
                  <view class="sent-meta">发起人：{{item.creatorName}}</view>
                  <view class="sent-date">📅 {{item.tripDate}}</view>
                </view>
                <view class="sent-status {{item.status}}">
                  <text wx:if="{{item.status === 'pending'}}">⏳</text>
                  <text wx:if="{{item.status === 'accepted'}}">✓</text>
                  <text wx:if="{{item.status === 'rejected'}}">✕</text>
                  {{item.statusText}}
                </view>
              </view>

              <!-- 申请中 -->
              <block wx:if="{{item.status === 'pending'}}">
                <view class="apply-detail">
                  <view class="apply-message" wx:if="{{item.message}}">
                    <text class="apply-label">我的申请留言：</text>
                    <text class="apply-value">{{item.message}}</text>
                  </view>
                  <view class="apply-time">申请时间：{{item.applyTime}}</view>
                </view>
                <view class="sent-actions">
                  <view class="action-btn cancel" catchtap="onCancelApply" data-id="{{item._id}}">取消申请</view>
                  <view class="action-btn primary" catchtap="onViewTrip" data-tripid="{{item.tripId}}">查看行程</view>
                </view>
              </block>

              <!-- 已同意 -->
              <block wx:if="{{item.status === 'accepted'}}">
                <view class="accepted-card">
                  <view class="accepted-tip">🎉 对方已同意您的申请</view>
                  <view class="contact-row" wx:if="{{item.creatorPhone}}">
                    <text class="contact-label">手机号：</text>
                    <text class="contact-value">{{item.creatorPhone}}</text>
                    <view class="copy-btn" catchtap="onCopyContact" data-value="{{item.creatorPhone}}">复制</view>
                  </view>
                  <view class="contact-row" wx:if="{{item.creatorWechat}}">
                    <text class="contact-label">微信号：</text>
                    <text class="contact-value">{{item.creatorWechat}}</text>
                    <view class="copy-btn" catchtap="onCopyContact" data-value="{{item.creatorWechat}}">复制</view>
                  </view>
                </view>
                <view class="sent-actions">
                  <view class="action-btn primary full" catchtap="onViewTrip" data-tripid="{{item.tripId}}">查看行程</view>
                </view>
              </block>

              <!-- 已拒绝 -->
              <block wx:if="{{item.status === 'rejected'}}">
                <view class="rejected-card">
                  <view class="rejected-tip">😔 对方拒绝了您的申请</view>
                </view>
                <view class="sent-actions">
                  <view class="action-btn cancel" catchtap="onReapply" data-tripid="{{item.tripId}}">重新申请</view>
                  <view class="action-btn primary" catchtap="onViewTrip" data-tripid="{{item.tripId}}">查看行程</view>
                </view>
              </block>
            </block>

          </view>
        </block>

        <!-- 空状态 -->
        <view class="empty-state" wx:else>
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无行程消息</text>
        </view>
      </view>

      <!-- 底部安全区 -->
      <view class="safe-bottom"></view>
    </scroll-view>
  </block>
</view>

<!-- 取消申请确认弹窗 -->
<view class="modal-mask" wx:if="{{showCancelModal}}" bindtap="onCloseCancelModal">
  <view class="modal-content" catchtap="preventBubble">
    <view class="modal-icon">⚠️</view>
    <view class="modal-title">确认取消申请？</view>
    <view class="modal-desc">取消后需要重新申请才能加入该行程</view>
    <view class="modal-actions">
      <view class="modal-btn cancel" catchtap="onCloseCancelModal">暂不取消</view>
      <view class="modal-btn confirm" catchtap="onConfirmCancel">确认取消</view>
    </view>
  </view>
</view>
