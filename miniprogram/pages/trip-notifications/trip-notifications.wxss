/* pages/trip-notifications/trip-notifications.wxss */

/* ========================================
   北京去哪玩 - 行程通知页面设计规格
   设计稿：docs/design-spec.html
   ======================================== */

page {
  /* 主色 */
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;

  /* 文字颜色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  /* 背景与边框 */
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;

  /* 功能色 */
  --danger-color: #FF4D4F;
  --success-color: #52C41A;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}


/* ========================================
   未登录状态
   居中布局，图标+标题+描述+按钮
   ======================================== */
.not-login {
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: var(--card-bg);
}

.not-login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 64rpx;
  text-align: center;
}

.not-login-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 40rpx;
}

.not-login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.not-login-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 96rpx;
  background: var(--primary-color);
  border-radius: 48rpx;
}

.login-btn:active {
  background: var(--primary-dark);
}

.login-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========================================
   加载状态
   ======================================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   消息内容区域
   ======================================== */
.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ========== Tab切换 ========== */
.tab-header {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: white;
  border-bottom: 2rpx solid var(--border-color);
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--bg-color);
  border-radius: 40rpx;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: var(--primary-color);
  color: white;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: var(--danger-color);
  color: white;
  border-radius: 16rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-badge {
  background: white;
  color: var(--danger-color);
}

/* ========================================
   通知列表
   ======================================== */
.notification-list {
  flex: 1;
  height: 100vh;
}

.list-content {
  padding: 24rpx;
}

/* ========== 通知卡片 ========== */
.notification-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.notification-card.handled {
  opacity: 0.6;
}

.notification-card:active {
  background: #FAFAFA;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar .avatar-image {
  width: 100%;
  height: 100%;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-meta {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ========== 卡片详情 ========== */
.card-detail {
  background: var(--bg-color);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.trip-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.trip-tag {
  padding: 8rpx 20rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 22rpx;
}

.detail-row {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  color: var(--text-secondary);
}

.detail-value {
  color: var(--text-secondary);
}

.text-ellipsis {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========== 操作按钮 ========== */
.card-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.reject {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.action-btn.agree {
  background: var(--primary-color);
  color: white;
}

/* ========== 状态标签 ========== */
.status-text {
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-text.agreed {
  color: var(--success-color);
}

.status-text.rejected,
.status-text.ignored {
  color: var(--text-hint);
}

/* ========== 已处理卡片（左右结构） ========== */
.card-handled {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-handled .header-info {
  flex: 1;
}

.card-handled .user-avatar {
  width: 96rpx;
  height: 96rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-wrapper {
  width: 240rpx;
  height: 240rpx;
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.1), rgba(107, 163, 232, 0.05));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.empty-icon {
  font-size: 144rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 28rpx 64rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
}

/* ========================================
   底部安全区
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* ========================================
   我发出的申请卡片
   ======================================== */
.notification-card {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

/* 发出申请的头部 */
.sent-header {
  display: flex;
  margin-bottom: 32rpx;
  gap: 24rpx;
}

.trip-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.trip-cover {
  width: 100%;
  height: 100%;
}

.trip-emoji {
  font-size: 56rpx;
}

.sent-info {
  flex: 1;
  min-width: 0;
}

.sent-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.sent-meta {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.sent-date {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 状态标签 */
.sent-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
  height: fit-content;
}

.sent-status.pending {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.sent-status.accepted {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.sent-status.rejected {
  background: rgba(255, 77, 79, 0.1);
  color: var(--danger-color);
}

/* 申请详情区域（申请中） */
.apply-detail {
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.apply-message {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.apply-label {
  color: var(--text-hint);
}

.apply-value {
  color: var(--text-secondary);
}

.apply-time {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 已同意卡片 */
.accepted-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.08), rgba(115, 209, 61, 0.08));
  border: 2rpx solid rgba(82, 196, 26, 0.2);
}

.accepted-tip {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--success-color);
  margin-bottom: 16rpx;
}

/* 已拒绝卡片 */
.rejected-card {
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 77, 79, 0.05);
  border: 2rpx solid rgba(255, 77, 79, 0.15);
}

.rejected-tip {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--danger-color);
}

/* 联系方式行 */
.contact-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}

.contact-icon {
  font-size: 28rpx;
}

.contact-label {
  font-size: 28rpx;
  color: var(--text-hint);
}

.contact-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  flex: 1;
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 12rpx;
  font-size: 24rpx;
}

/* 操作按钮区域 */
.sent-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn.cancel {
  flex: 1;
  padding: 20rpx;
  background: rgba(255, 77, 79, 0.1);
  color: var(--danger-color);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  flex: 1;
  padding: 20rpx;
  background: var(--primary-color);
  color: white;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary.full {
  flex: none;
  width: 100%;
}

/* ========================================
   取消申请弹窗
   ======================================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.modal-btn.confirm {
  background: var(--danger-color);
  color: white;
}
