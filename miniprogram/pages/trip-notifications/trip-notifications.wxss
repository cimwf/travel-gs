/* pages/trip-notifications/trip-notifications.wxss */

/* ========================================
   北京去哪玩 - 行程通知页面设计规格
   设计稿：docs/design-spec.html
   ======================================== */

page {
  /* 主色 */
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;

  /* 文字颜色 */
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  /* 背景与边框 */
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --border-color: #E8E8F0;

  /* 功能色 */
  --danger-color: #FF4D4F;
  --success-color: #52C41A;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

page {
  background: var(--bg-color);
  width: 100%;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}


/* ========================================
   未登录状态
   居中布局，图标+标题+描述+按钮
   ======================================== */
.not-login {
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: var(--card-bg);
}

.not-login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 64rpx;
  text-align: center;
}

.not-login-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 40rpx;
}

.not-login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.not-login-desc {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 96rpx;
  background: var(--primary-color);
  border-radius: 48rpx;
}

.login-btn:active {
  background: var(--primary-dark);
}

.login-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========================================
   加载状态
   ======================================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========================================
   通知列表
   ======================================== */
.notification-list {
  flex: 1;
  height: 100vh;
}

.list-content {
  padding: 24rpx;
}

/* ========== 通知卡片 ========== */
.notification-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.notification-card.handled {
  opacity: 0.6;
}

.notification-card:active {
  background: #FAFAFA;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 600;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar .avatar-image {
  width: 100%;
  height: 100%;
}

.header-info {
  flex: 1;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-meta {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ========== 卡片详情 ========== */
.card-detail {
  background: var(--bg-color);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.trip-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.trip-tag {
  padding: 8rpx 20rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 22rpx;
}

.detail-row {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  color: var(--text-secondary);
}

.detail-value {
  color: var(--text-secondary);
}

.text-ellipsis {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========== 操作按钮 ========== */
.card-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.reject {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.action-btn.agree {
  background: var(--primary-color);
  color: white;
}

/* ========== 状态标签 ========== */
.status-text {
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-text.agreed {
  color: var(--success-color);
}

.status-text.rejected,
.status-text.ignored {
  color: var(--text-hint);
}

/* ========== 已处理卡片（左右结构） ========== */
.card-handled {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-handled .header-info {
  flex: 1;
}

.card-handled .user-avatar {
  width: 96rpx;
  height: 96rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 80rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ========================================
   底部安全区
   ======================================== */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 32rpx);
}
