/* pages/edit-profile/edit-profile.wxss */

/* ========================================
   设计系统 - Design Token System
   ======================================== */
page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --primary-bg: rgba(74, 144, 226, 0.15);

  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;

  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;

  --border-color: #E8E8F0;
  --divider-color: #F0F0F5;

  --danger-color: #FF4D4F;

  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);

  --radius-sm: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* ========== 顶部导航 ========== */
.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: white;
  z-index: 100;
  border-bottom: 2rpx solid var(--border-color);
}

.nav-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.nav-placeholder {
  width: 72rpx;
}

.nav-placeholder-area {
  flex-shrink: 0;
}

/* ========== 头像卡片 ========== */
.profile-header-card {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 56rpx 40rpx;
  text-align: center;
  position: relative;
}

.avatar-container {
  position: relative;
  display: inline-block;
}

.avatar-large {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.avatar-large-placeholder {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 56rpx;
  height: 56rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.profile-nickname {
  color: white;
  font-size: 44rpx;
  font-weight: 700;
  margin-top: 24rpx;
}

.profile-id {
  color: rgba(255, 255, 255, 0.85);
  font-size: 26rpx;
  margin-top: 8rpx;
}

.background-edit-hint {
  position: absolute;
  bottom: 16rpx;
  right: 60rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(0, 0, 0, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.content-section-view {
  width: 100%;
  padding-left: 20rpx;
  padding-right: 20rpx;
}

/* ========== 内容区域 ========== */
.content-section {
  padding: 32rpx;
  padding-bottom: 64rpx;
}

/* ========== 信息分组 ========== */
.info-group {
  background: white;
  border-radius: var(--radius-xl);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.group-header {
  padding: 36rpx 40rpx;
  border-bottom: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
}

.group-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-left: 24rpx;
  flex: 1;
}

.group-arrow {
  color: #ccc;
  font-size: 24rpx;
}


.group-content {
  padding: 0 40rpx 40rpx;
}

/* ========== 信息行 ========== */
.info-row {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid var(--divider-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 144rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
}

.info-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
  background: transparent;
}

.input-placeholder {
  color: var(--text-hint);
}

.info-value-arrow {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.info-value {
  font-size: 30rpx;
  color: var(--text-primary);
}

.arrow {
  color: #ccc;
  margin-left: 8rpx;
}

/* ========== 性别标签 ========== */
.gender-tags {
  flex: 1;
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.gender-tag {
  padding: 16rpx 36rpx;
  background: #f5f5f5;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.gender-tag.active {
  background: var(--primary-color);
  color: white;
}

/* ========== 自我描述文本域 ========== */
.bio-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 28rpx;
  border: 2rpx solid #eee;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  background: #fafafa;
  box-sizing: border-box;
  margin-top: 32rpx;
}

.textarea-placeholder {
  color: var(--text-hint);
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
}

/* ========== 旅行照片 ========== */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
}

.photo-add {
  aspect-ratio: 1;
  background: #f8f9fa;
  border: 4rpx dashed #ddd;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 56rpx;
  color: #ccc;
}

.photo-tip {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 12rpx;
  text-align: center;
}

/* ========== 计数器 ========== */
.counter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--divider-color);
}

.counter-row:last-child {
  border-bottom: none;
}

.counter-label {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.counter-control {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.counter-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text-secondary);
}

.counter-value {
  font-size: 36rpx;
  font-weight: 700;
  min-width: 56rpx;
  text-align: center;
}

/* ========== 标签选择 ========== */
.tag-section {
  margin-bottom: 32rpx;
}

.tag-section:last-child {
  margin-bottom: 0;
}

.tag-section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tag-item.active {
  background: var(--primary-bg);
  color: var(--primary-color);
  border: 3rpx solid var(--primary-color);
}

/* ========== 行程节奏 ========== */
.pace-options {
  display: flex;
  gap: 20rpx;
}

.pace-item {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.pace-item.active {
  background: var(--primary-bg);
  color: var(--primary-color);
  border: 3rpx solid var(--primary-color);
}

/* ========== 保存按钮 ========== */
.save-section-bottom {
  width: 100%;
  padding: 32rpx 0;
}

.save-btn {
  width: 100%;
  flex: 1;
  height: 96rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.35);
}

.save-btn::after {
  border: none;
}
