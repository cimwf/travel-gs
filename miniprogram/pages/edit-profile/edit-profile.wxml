<!--
  个人信息编辑页 (edit-profile)
  ================================
  设计稿：docs/design-spec.html
-->

<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-top">
      <view class="nav-back" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="nav-title">编辑资料</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 占位区域 -->
  <view class="nav-placeholder-area" style="height: {{statusBarHeight + 44}}px;"></view>

  <!-- 头像卡片 -->
  <view class="profile-header-card" style="{{userInfo.background ? 'background-image: url(' + userInfo.background + '); background-size: cover; background-position: center;' : ''}}" bindtap="onChooseBackground">
    <view class="avatar-container" catchtap="onChooseAvatar">
      <image class="avatar-large" src="{{userInfo.avatar || defaultAvatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}"></image>
      <view class="avatar-large-placeholder" wx:else>
        <text>👤</text>
      </view>
      <view class="avatar-edit-badge">
        <text>📷</text>
      </view>
    </view>
    <view class="profile-nickname">{{userInfo.nickname || '旅行达人'}}</view>
    <view class="profile-id">ID: {{userInfo.userId || 'BJ20260406'}}</view>
    <view class="background-edit-hint">点击更换背景</view>
  </view>

  <view class="content-section-view">
    <view class="content-section">
      <!-- 基础信息分组 -->
      <view class="info-group">
        <view class="group-header">
          <view class="group-icon" style="background: linear-gradient(135deg, #FFF5F0, #FFE8DB);">
            <text>👤</text>
          </view>
          <text class="group-title">基础信息</text>
          <text class="group-arrow">▼</text>
        </view>
        <view class="group-content">
          <view class="info-row">
            <text class="info-label">昵称</text>
            <input class="info-input" placeholder="请输入昵称" placeholder-class="input-placeholder" value="{{userInfo.nickname}}" maxlength="12" bindinput="onNicknameInput" />
          </view>
          <view class="info-row">
            <text class="info-label">性别</text>
            <view class="gender-tags">
              <view class="gender-tag {{userInfo.gender === 'male' ? 'active' : ''}}" data-value="male" bindtap="onGenderChange">男</view>
              <view class="gender-tag {{userInfo.gender === 'female' ? 'active' : ''}}" data-value="female" bindtap="onGenderChange">女</view>
              <view class="gender-tag {{userInfo.gender === 'secret' ? 'active' : ''}}" data-value="secret" bindtap="onGenderChange">保密</view>
            </view>
          </view>
        </view>
      </view>

          <!-- 旅行照片分组 -->
      <view class="info-group">
        <view class="group-header">
          <view class="group-icon" style="background: linear-gradient(135deg, #FFF0E5, #FFF9F5);">
            <text>📸</text>
          </view>
          <text class="group-title">旅行照片</text>
          <text class="group-arrow">▼</text>
        </view>
        <view class="group-content">
          <view class="photo-grid">
            <view class="photo-item" wx:for="{{userInfo.photos}}" wx:key="index" data-index="{{index}}" bindtap="onPreviewPhoto">
              <image class="photo-image" src="{{item}}" mode="aspectFill"></image>
              <view class="photo-delete" data-index="{{index}}" catchtap="onDeletePhoto">×</view>
            </view>
            <view class="photo-add" wx:if="{{userInfo.photos.length < 9}}" bindtap="onAddPhoto">
              <text class="photo-add-icon">+</text>
            </view>
          </view>
          <view class="photo-tip">已上传 {{userInfo.photos.length || 0}}/9 张，点击图片可删除</view>
        </view>
      </view>

      <!-- 自我描述分组 -->
      <view class="info-group">
        <view class="group-header">
          <view class="group-icon" style="background: linear-gradient(135deg, #E8F4FF, #F0F8FF);">
            <text>📝</text>
          </view>
          <text class="group-title">自我描述</text>
          <text class="group-arrow">▼</text>
        </view>
        <view class="group-content">
          <textarea class="bio-textarea" placeholder="介绍一下自己，让队友更了解你～" placeholder-class="textarea-placeholder" value="{{userInfo.bio}}" maxlength="200" bindinput="onBioInput" />
          <view class="textarea-count">{{userInfo.bio.length || 0}}/200字</view>
        </view>
      </view>

      <!-- 保存按钮 -->
      <view class="save-section-bottom">
        <button class="save-btn" bindtap="onSave" loading="{{saving}}">保存修改</button>
      </view>
    </view>
  </view>
</view>
