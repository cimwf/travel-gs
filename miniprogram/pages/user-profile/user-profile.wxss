/* pages/user-profile/user-profile.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 用户信息卡片 */
.user-card {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 64rpx 40rpx;
  text-align: center;
}

.user-avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
}

.user-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.95);
  border: 8rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}

.user-avatar-text {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  border: 8rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}

.user-name {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  margin-top: 32rpx;
}

.user-id {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

/* 统计数据 */
.user-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

/* 内容区域 */
.content {
  width: 100%;
  padding: 32rpx;
}

/* 卡片通用样式 */
.section-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 个人简介 */
.bio-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 旅行照片 */
.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

/* 行程卡片 */
.trips-card {
  padding: 0;
  overflow: hidden;
}

.trips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.trips-header .section-title {
  margin-bottom: 0;
}

.trips-count {
  font-size: 26rpx;
  color: var(--text-hint);
}

.trip-list {
  padding: 32rpx;
}

.trip-item {
  display: flex;
  gap: 24rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.trip-item:last-child {
  margin-bottom: 0;
}

.trip-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.trip-cover-img {
  width: 100%;
  height: 100%;
}

.trip-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.trip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.trip-meta {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.trip-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.trip-tag {
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 226, 0.1);
  color: var(--primary-color);
  border-radius: 20rpx;
  font-size: 22rpx;
}

.trip-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}
