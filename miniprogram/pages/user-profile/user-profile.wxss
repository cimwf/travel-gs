/* pages/user-profile/user-profile.wxss */

page {
  --primary-color: #4A90E2;
  --primary-light: #6BA3E8;
  --primary-dark: #357ABD;
  --bg-color: #F5F7FA;
  --text-primary: #1A1A2E;
  --text-secondary: #4A4A68;
  --text-hint: #8E8EA0;
  --border-color: #E8E8F0;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: var(--text-hint);
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 用户信息卡片 */
.user-card {
  width: 100%;
  text-align: center;
  position: relative;
  min-height: 400rpx;
  overflow: hidden;
}

.user-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.user-card-overlay {
  padding: 64rpx 40rpx;
  position: relative;
  z-index: 1;
  background: rgba(0, 0, 0, 0.35);
}

.user-avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
}

.user-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.95);
  border: 8rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}

.user-avatar-text {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  border: 8rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
}

.user-name {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  margin-top: 32rpx;
}

.user-id {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

.user-id-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 8rpx;
}

.user-gender {
  width: 32rpx;
  height: 32rpx;
}

.user-meta-pill {
  min-width: auto;
  padding: 0;
  color: rgba(255,255,255,0.92);
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
}

.profile-actions {
  display: flex;
  justify-content: center;
  margin-top: 28rpx;
}

.edit-profile-btn {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  border: 2rpx solid rgba(255,255,255,0.38);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 72rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12);
  backdrop-filter: blur(12rpx);
}

.edit-profile-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

/* 统计数据 */
.user-stats {
  display: flex;
  justify-content: center;
  gap: 80rpx;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

/* 内容区域 */
.content {
  width: 100%;
  padding: 32rpx;
}

/* 卡片通用样式 */
.section-card {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 个人简介 */
.bio-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 旅行照片 */
.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

/* 行程卡片 */
.trips-card {
  padding: 0;
  overflow: hidden;
}

.trips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.trips-header .section-title {
  margin-bottom: 0;
}

.trips-count {
  font-size: 26rpx;
  color: var(--text-hint);
}

.trip-list {
  padding: 32rpx;
}

.profile-trip-list {
  padding: 0;
}

.trip-card {
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.profile-trip-list .trip-card {
  background: #FFFFFF;
  box-shadow: var(--shadow-sm);
}

.trip-card:last-child {
  margin-bottom: 0;
}

.trip-header {
  display: flex;
  gap: 24rpx;
}

.trip-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trip-emoji {
  font-size: 64rpx;
}

.trip-info {
  flex: 1;
  min-width: 0;
}

.trip-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.trip-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.35;
}

.trip-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #52C41A;
  background: rgba(82, 196, 26, 0.1);
}

.trip-status.ongoing {
  background: rgba(74, 144, 226, 0.12);
  color: #4A90E2;
}

.trip-status.almost-full {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.trip-status.full {
  background: rgba(140, 140, 160, 0.1);
  color: #8E8EA0;
}

.trip-status.stopped,
.trip-status.cancelled {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.trip-status.ended {
  background: rgba(140, 140, 160, 0.1);
  color: #8E8EA0;
}

.trip-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 10rpx;
}

.meta-dot {
  color: #c0c4cc;
}

.trip-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.trip-footer-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.participants {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.participant-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #fff;
  margin-left: -10rpx;
  background: #e8e8f0;
}

.participant-avatar:first-child {
  margin-left: 0;
}

.trip-need,
.publish-time {
  font-size: 24rpx;
  color: var(--text-hint);
}

.trip-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}
