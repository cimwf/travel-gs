<!--pages/user-profile/user-profile.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <image class="user-bg-image" src="{{userInfo.background || defaultBackground}}" mode="aspectFill"></image>
      <view class="user-card-overlay">
        <view class="user-avatar-wrap">
          <image class="user-avatar" src="{{userInfo.avatar}}" wx:if="{{userInfo.avatar}}" mode="aspectFill"></image>
          <view class="user-avatar-text" wx:else>
            <text>👤</text>
          </view>
        </view>
        <view class="user-name">{{userInfo.nickname || '旅行者'}}</view>
        <view class="user-id-row">
          <text class="user-id">ID: {{userInfo.userId || '未设置'}}</text>
          <text class="user-meta-pill" wx:if="{{userInfo.age}}">{{userInfo.age}}</text>
          <image class="user-gender" src="/images/male.svg" wx:if="{{userInfo.gender === 'male'}}" />
          <image class="user-gender" src="/images/female.svg" wx:if="{{userInfo.gender === 'female'}}" />
        </view>
        <view class="profile-actions" wx:if="{{isCurrentUser}}">
          <view class="edit-profile-btn" bindtap="onEditProfile">编辑资料</view>
        </view>
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="content">
      <!-- 个人简介 -->
      <view class="section-card" wx:if="{{userInfo.bio}}">
        <view class="section-title">📝 个人简介</view>
        <view class="bio-text">{{userInfo.bio}}</view>
      </view>

      <!-- 旅行照片 -->
      <view class="section-card" wx:if="{{photos.length > 0}}">
        <view class="section-title">📸 旅行照片</view>
        <view class="photos-grid">
          <view class="photo-item" wx:for="{{photos}}" wx:key="index" bindtap="onPhotoTap" data-index="{{index}}">
            <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
          </view>
        </view>
      </view>

      <!-- 发布的行程 -->
      <view class="trip-list profile-trip-list" wx:if="{{trips.length > 0}}">
        <view class="trip-card" wx:for="{{trips}}" wx:key="_id" bindtap="onTripTap" data-id="{{item._id}}">
          <view class="trip-header">
            <image class="trip-img" src="{{item.placeCoverImage}}" mode="aspectFill" wx:if="{{item.placeCoverImage}}"></image>
            <view class="trip-img" style="background: {{item.imgBg}};" wx:else>
              <text class="trip-emoji">{{item.emoji}}</text>
            </view>
            <view class="trip-info">
              <view class="trip-title-row">
                <view class="trip-title">{{item.displayTitle || item.placeName}}</view>
                <view class="trip-status {{item.statusClass}}">{{item.statusText}}</view>
              </view>
              <view class="trip-meta">
                <text>📅 {{item.dateText}}</text>
                <text class="meta-dot">·</text>
                <text>📍 {{item.departure || '待定'}}</text>
              </view>
              <view class="trip-meta trip-meta-second">
                <text>{{item.carText}}</text>
                <text class="meta-dot" wx:if="{{item.priceText}}">·</text>
                <text wx:if="{{item.priceText}}">{{item.priceText}}</text>
              </view>
            </view>
          </view>

          <view class="trip-footer">
            <view class="trip-footer-left">
              <view class="participants">
                <image class="participant-avatar" wx:for="{{item.participants}}" wx:for-item="p" wx:for-index="pIndex" wx:key="userId" src="{{p.avatar}}" mode="aspectFill"></image>
              </view>
              <text class="trip-need" wx:if="{{item.needCount > 0}}">还差{{item.needCount}}人</text>
            </view>
            <text class="publish-time">{{item.publishTime}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
