<!--pages/user-profile/user-profile.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-avatar-wrap">
        <image class="user-avatar" src="{{userInfo.avatar}}" wx:if="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="user-avatar-text" wx:else>
          <text>👤</text>
        </view>
      </view>
      <view class="user-name">{{userInfo.nickname || '旅行者'}}</view>
      <view class="user-id">ID: {{userInfo.userCode || 'BJ20260418'}}</view>
    </view>

    <!-- 内容区域 -->
    <view class="content">
      <!-- 个人简介 -->
      <view class="section-card" wx:if="{{userInfo.bio}}">
        <view class="section-title">📝 个人简介</view>
        <view class="bio-text">{{userInfo.bio}}</view>
      </view>

      <!-- 旅行照片 -->
      <view class="section-card" wx:if="{{photos.length > 0}}">
        <view class="section-title">📸 旅行照片</view>
        <view class="photos-grid">
          <view class="photo-item" wx:for="{{photos}}" wx:key="index">
            <image class="photo-img" src="{{item}}" mode="aspectFill"></image>
          </view>
        </view>
      </view>

      <!-- 发布的行程 -->
      <view class="section-card trips-card">
        <view class="trips-header">
          <view class="section-title">📍 发布的行程</view>
          <text class="trips-count">{{trips.length}}个</text>
        </view>

        <view class="trip-list" wx:if="{{trips.length > 0}}">
          <view class="trip-item" wx:for="{{trips}}" wx:key="_id" bindtap="onTripTap" data-id="{{item._id}}">
            <view class="trip-cover">
              <image class="trip-cover-img" src="{{item.placeImage}}" mode="aspectFill"></image>
            </view>
            <view class="trip-info">
              <view class="trip-title">{{item.title || item.placeName}}</view>
              <view class="trip-meta">{{item.date}} · {{item.duration || '1天'}}</view>
              <view class="trip-tags">
                <text class="trip-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">{{tag}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:else>
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无发布的行程</text>
        </view>
      </view>
    </view>
  </block>
</view>
