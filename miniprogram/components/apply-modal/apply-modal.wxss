/* components/apply-modal/apply-modal.wxss */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 40rpx;
  padding: 48rpx;
  box-shadow: 0 40rpx 120rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 32rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-icon {
  font-size: 56rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #8E8EA0;
}

.modal-body {
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #4A4A68;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #FF4D4F;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #E8E8F0;
  border-radius: 24rpx;
  font-size: 30rpx;
  background: #F5F7FA;
  box-sizing: border-box;
}

.form-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(74, 144, 226, 0.06);
  border-radius: 16rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #4A90E2;
}

.tip-icon {
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  padding: 24rpx 32rpx;
  border: 2rpx solid #E8E8F0;
  border-radius: 24rpx;
  font-size: 30rpx;
  background: #F5F7FA;
  height: 160rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.modal-btn-cancel {
  flex: 1;
  background: #F5F7FA;
  color: #4A4A68;
}

.modal-btn-confirm {
  flex: 2;
  background: #4A90E2;
  color: white;
}
